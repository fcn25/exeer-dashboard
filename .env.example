# Supabase (client) — dev server reads .env
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Capacitor / iOS / Android production builds bake env at compile time.
# Copy real values to .env.production before: npm run build && npx cap sync ios
# See .env.production.example

# Gemini (client — Flash only; never commit real keys)
VITE_GEMINI_API_KEY=your-gemini-api-key
# Optional override; must be a Flash model (e.g. gemini-1.5-flash). Pro/Ultra are rejected.
# VITE_GEMINI_MODEL=gemini-1.5-flash

# Edge Function `invite-employee` (set in Supabase Dashboard → Edge Functions → Secrets)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  (never expose in the browser)

# Database seed: node scripts/seed.js
# SUPABASE_URL=https://your-project.supabase.co  (or reuse VITE_SUPABASE_URL)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres  (optional; runs full seed.sql)
