# Production / Capacitor mobile build — copied into the static bundle at `npm run build`.
# Copy to .env.production and replace with your real Supabase project values:
#   cp .env.production.example .env.production
#
# Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Required for company settings save/seed (service role — treat as secret)
# VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini (Flash only — required for المهام الذكية)
# VITE_GEMINI_API_KEY=your-gemini-api-key
VITE_GEMINI_MODEL=gemini-2.5-flash
