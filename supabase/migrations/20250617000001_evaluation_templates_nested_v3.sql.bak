insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Compliance', 'تقييم اللياقة المهنية', '{"version":3,"title_en":"Professional Fitness Assessment","title_ar":"تقييم اللياقة المهنية","categories":[{"title_ar":"اللياقة المهنية","criteria":[{"title_ar":"ملاءمة المهارات للدور الحالي","questions":[{"id":"q1","text":"هل تحمل التراخيص والشهادات اللازمة المطلوبة لمهنتك؟","type":"boolean","min":1,"max":5,"ratingHint":"طريقة التقييم: نعم / لا","text_ar":"هل تحمل التراخيص والشهادات اللازمة المطلوبة لمهنتك؟","text_en":""},{"id":"q3","text":"هل لديك القدرة البدنية والذهنية لأداء مهام عملك الحالي؟","type":"boolean","min":1,"max":5,"ratingHint":"طريقة التقييم: نعم / لا","text_ar":"هل لديك القدرة البدنية والذهنية لأداء مهام عملك الحالي؟","text_en":""},{"id":"q5","text":"يرجى إرفاق مستند يوضح تاريخ آخر تحديث لشهادتك المهنية.","type":"file","min":1,"max":5,"ratingHint":"طريقة التقييم: مرفق","text_ar":"يرجى إرفاق مستند يوضح تاريخ آخر تحديث لشهادتك المهنية.","text_en":""}]},{"title_ar":"الاستعداد للمهام الأكثر تعقيداً","questions":[{"id":"q2","text":"هل أنت ملتزم بمعايير السلامة والمعايير المهنية الوطنية؟","type":"boolean","min":1,"max":5,"ratingHint":"طريقة التقييم: نعم / لا","text_ar":"هل أنت ملتزم بمعايير السلامة والمعايير المهنية الوطنية؟","text_en":""},{"id":"q4","text":"يرجى إرفاق صورة أو مستند حديث يثبت شهادتك المهنية.","type":"file","min":1,"max":5,"ratingHint":"طريقة التقييم: مرفق","text_ar":"يرجى إرفاق صورة أو مستند حديث يثبت شهادتك المهنية.","text_en":""}]}]}],"questions":[{"id":"q1","text":"هل تحمل التراخيص والشهادات اللازمة المطلوبة لمهنتك؟","type":"boolean","min":1,"max":5,"ratingHint":"طريقة التقييم: نعم / لا","text_ar":"هل تحمل التراخيص والشهادات اللازمة المطلوبة لمهنتك؟","text_en":"","category_ar":"اللياقة المهنية","section_ar":"اللياقة المهنية","criterion_ar":"ملاءمة المهارات للدور الحالي"},{"id":"q3","text":"هل لديك القدرة البدنية والذهنية لأداء مهام عملك الحالي؟","type":"boolean","min":1,"max":5,"ratingHint":"طريقة التقييم: نعم / لا","text_ar":"هل لديك القدرة البدنية والذهنية لأداء مهام عملك الحالي؟","text_en":"","category_ar":"اللياقة المهنية","section_ar":"اللياقة المهنية","criterion_ar":"ملاءمة المهارات للدور الحالي"},{"id":"q5","text":"يرجى إرفاق مستند يوضح تاريخ آخر تحديث لشهادتك المهنية.","type":"file","min":1,"max":5,"ratingHint":"طريقة التقييم: مرفق","text_ar":"يرجى إرفاق مستند يوضح تاريخ آخر تحديث لشهادتك المهنية.","text_en":"","category_ar":"اللياقة المهنية","section_ar":"اللياقة المهنية","criterion_ar":"ملاءمة المهارات للدور الحالي"},{"id":"q2","text":"هل أنت ملتزم بمعايير السلامة والمعايير المهنية الوطنية؟","type":"boolean","min":1,"max":5,"ratingHint":"طريقة التقييم: نعم / لا","text_ar":"هل أنت ملتزم بمعايير السلامة والمعايير المهنية الوطنية؟","text_en":"","category_ar":"اللياقة المهنية","section_ar":"اللياقة المهنية","criterion_ar":"الاستعداد للمهام الأكثر تعقيداً"},{"id":"q4","text":"يرجى إرفاق صورة أو مستند حديث يثبت شهادتك المهنية.","type":"file","min":1,"max":5,"ratingHint":"طريقة التقييم: مرفق","text_ar":"يرجى إرفاق صورة أو مستند حديث يثبت شهادتك المهنية.","text_en":"","category_ar":"اللياقة المهنية","section_ar":"اللياقة المهنية","criterion_ar":"الاستعداد للمهام الأكثر تعقيداً"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم اللياقة المهنية'
);

