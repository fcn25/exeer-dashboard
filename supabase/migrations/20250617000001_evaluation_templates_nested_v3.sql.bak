insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Production', 'تقييم كفاءة الإنتاج والجودة', '{"version":3,"title_en":"Production Efficiency and Quality Evaluation","title_ar":"تقييم كفاءة الإنتاج والجودة","categories":[{"title_ar":"كفاءة الإنتاج","criteria":[{"title_ar":"معدل استغلال خطوط الإنتاج","questions":[{"id":"q1","text":"ما مدى استمرارية تشغيل خطوط الإنتاج دون انقطاعات غير متوقعة أو أعطال فنية؟","type":"rating_0_100","min":0,"max":100,"ratingHint":"طريقة التقييم: مقياس من 0 إلى 100","text_ar":"ما مدى استمرارية تشغيل خطوط الإنتاج دون انقطاعات غير متوقعة أو أعطال فنية؟","text_en":""},{"id":"q5","text":"هل هناك التزام تام بارتداء معدات الوقاية الشخصية (PPE) من قبل جميع العمال في منطقة الإنتاج؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل هناك التزام تام بارتداء معدات الوقاية الشخصية (PPE) من قبل جميع العمال في منطقة الإنتاج؟","text_en":""}]},{"title_ar":"نسبة الهدر والتوقفات غير المخططة","questions":[{"id":"q2","text":"كيف تقيم سرعة وكفاءة فريق الصيانة في التعامل مع بلاغات الأعطال الطارئة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"كيف تقيم سرعة وكفاءة فريق الصيانة في التعامل مع بلاغات الأعطال الطارئة؟","text_en":""},{"id":"q6","text":"هل تشعر أن الإضاءة، والتهوية، وتخطيط المساحة في صالة الإنتاج تساعد في الحفاظ على التركيز والسلامة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"هل تشعر أن الإضاءة، والتهوية، وتخطيط المساحة في صالة الإنتاج تساعد في الحفاظ على التركيز والسلامة؟","text_en":""}]}]},{"title_ar":"الجودة","criteria":[{"title_ar":"معدل العيوب وإعادة العمل","questions":[{"id":"q3","text":"ما هو السبب الرئيسي لوجود منتجات معيبة (Defective) أو هدر في قسمك حالياً؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"ما هو السبب الرئيسي لوجود منتجات معيبة (Defective) أو هدر في قسمك حالياً؟","text_en":""},{"id":"q7","text":"إذا طُلب منك اقتراح تغيير واحد في تسلسل التصنيع لزيادة الإنتاج اليومي بنسبة 15% دون زيادة التكاليف، فماذا سيكون؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"إذا طُلب منك اقتراح تغيير واحد في تسلسل التصنيع لزيادة الإنتاج اليومي بنسبة 15% دون زيادة التكاليف، فماذا سيكون؟","text_en":""}]},{"title_ar":"الالتزام بمعايير السلامة المهنية","questions":[{"id":"q4","text":"صف الإجراء الفوري الذي تتخذه عند اكتشاف مشكلة في الجودة أثناء عملية التصنيع.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"صف الإجراء الفوري الذي تتخذه عند اكتشاف مشكلة في الجودة أثناء عملية التصنيع.","text_en":""}]}]}],"questions":[{"id":"q1","text":"ما مدى استمرارية تشغيل خطوط الإنتاج دون انقطاعات غير متوقعة أو أعطال فنية؟","type":"rating_0_100","min":0,"max":100,"ratingHint":"طريقة التقييم: مقياس من 0 إلى 100","text_ar":"ما مدى استمرارية تشغيل خطوط الإنتاج دون انقطاعات غير متوقعة أو أعطال فنية؟","text_en":"","category_ar":"كفاءة الإنتاج","section_ar":"كفاءة الإنتاج","criterion_ar":"معدل استغلال خطوط الإنتاج"},{"id":"q5","text":"هل هناك التزام تام بارتداء معدات الوقاية الشخصية (PPE) من قبل جميع العمال في منطقة الإنتاج؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل هناك التزام تام بارتداء معدات الوقاية الشخصية (PPE) من قبل جميع العمال في منطقة الإنتاج؟","text_en":"","category_ar":"كفاءة الإنتاج","section_ar":"كفاءة الإنتاج","criterion_ar":"معدل استغلال خطوط الإنتاج"},{"id":"q2","text":"كيف تقيم سرعة وكفاءة فريق الصيانة في التعامل مع بلاغات الأعطال الطارئة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"كيف تقيم سرعة وكفاءة فريق الصيانة في التعامل مع بلاغات الأعطال الطارئة؟","text_en":"","category_ar":"كفاءة الإنتاج","section_ar":"كفاءة الإنتاج","criterion_ar":"نسبة الهدر والتوقفات غير المخططة"},{"id":"q6","text":"هل تشعر أن الإضاءة، والتهوية، وتخطيط المساحة في صالة الإنتاج تساعد في الحفاظ على التركيز والسلامة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"هل تشعر أن الإضاءة، والتهوية، وتخطيط المساحة في صالة الإنتاج تساعد في الحفاظ على التركيز والسلامة؟","text_en":"","category_ar":"كفاءة الإنتاج","section_ar":"كفاءة الإنتاج","criterion_ar":"نسبة الهدر والتوقفات غير المخططة"},{"id":"q3","text":"ما هو السبب الرئيسي لوجود منتجات معيبة (Defective) أو هدر في قسمك حالياً؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"ما هو السبب الرئيسي لوجود منتجات معيبة (Defective) أو هدر في قسمك حالياً؟","text_en":"","category_ar":"الجودة","section_ar":"الجودة","criterion_ar":"معدل العيوب وإعادة العمل"},{"id":"q7","text":"إذا طُلب منك اقتراح تغيير واحد في تسلسل التصنيع لزيادة الإنتاج اليومي بنسبة 15% دون زيادة التكاليف، فماذا سيكون؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"إذا طُلب منك اقتراح تغيير واحد في تسلسل التصنيع لزيادة الإنتاج اليومي بنسبة 15% دون زيادة التكاليف، فماذا سيكون؟","text_en":"","category_ar":"الجودة","section_ar":"الجودة","criterion_ar":"معدل العيوب وإعادة العمل"},{"id":"q4","text":"صف الإجراء الفوري الذي تتخذه عند اكتشاف مشكلة في الجودة أثناء عملية التصنيع.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"صف الإجراء الفوري الذي تتخذه عند اكتشاف مشكلة في الجودة أثناء عملية التصنيع.","text_en":"","category_ar":"الجودة","section_ar":"الجودة","criterion_ar":"الالتزام بمعايير السلامة المهنية"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم كفاءة الإنتاج والجودة'
);

