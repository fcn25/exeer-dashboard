    questions_jsonb = '{"version":3,"title_en":"Company Survey","title_ar":"استبيان الشركة العام","categories":[{"title_ar":"الأداء المؤسسي","criteria":[{"title_ar":"تحقيق أهداف الإيرادات والربحية المخططة","questions":[{"id":"q1","text":"ما مدى رضاك عن بيئة العمل؟","type":"rating_0_10","min":0,"max":10,"ratingHint":"طريقة التقييم: مقياس من 0 إلى 10","text_ar":"ما مدى رضاك عن بيئة العمل؟","text_en":""}]},{"title_ar":"كفاءة استخدام الموارد والميزانيات","questions":[{"id":"q2","text":"هل لديك الموارد والأدوات الكافية لأداء عملك بفعالية؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"هل لديك الموارد والأدوات الكافية لأداء عملك بفعالية؟","text_en":""}]}]},{"title_ar":"الاستدامة","criteria":[{"title_ar":"جاهزية المنشأة للتوسع أو التحول","questions":[{"id":"q3","text":"ما مدى وضوح رؤية الإدارة للمنشأة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"ما مدى وضوح رؤية الإدارة للمنشأة؟","text_en":""}]},{"title_ar":"مستوى المخاطر التشغيلية والامتثال","questions":[{"id":"q4","text":"ما مدى دعم قسم الموارد البشرية في تلبية احتياجاتك؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"ما مدى دعم قسم الموارد البشرية في تلبية احتياجاتك؟","text_en":""}]}]}],"questions":[{"id":"q1","text":"ما مدى رضاك عن بيئة العمل؟","type":"rating_0_10","min":0,"max":10,"ratingHint":"طريقة التقييم: مقياس من 0 إلى 10","text_ar":"ما مدى رضاك عن بيئة العمل؟","text_en":"","category_ar":"الأداء المؤسسي","section_ar":"الأداء المؤسسي","criterion_ar":"تحقيق أهداف الإيرادات والربحية المخططة"},{"id":"q2","text":"هل لديك الموارد والأدوات الكافية لأداء عملك بفعالية؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"هل لديك الموارد والأدوات الكافية لأداء عملك بفعالية؟","text_en":"","category_ar":"الأداء المؤسسي","section_ar":"الأداء المؤسسي","criterion_ar":"كفاءة استخدام الموارد والميزانيات"},{"id":"q3","text":"ما مدى وضوح رؤية الإدارة للمنشأة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"ما مدى وضوح رؤية الإدارة للمنشأة؟","text_en":"","category_ar":"الاستدامة","section_ar":"الاستدامة","criterion_ar":"جاهزية المنشأة للتوسع أو التحول"},{"id":"q4","text":"ما مدى دعم قسم الموارد البشرية في تلبية احتياجاتك؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"ما مدى دعم قسم الموارد البشرية في تلبية احتياجاتك؟","text_en":"","category_ar":"الاستدامة","section_ar":"الاستدامة","criterion_ar":"مستوى المخاطر التشغيلية والامتثال"}]}'::jsonb
