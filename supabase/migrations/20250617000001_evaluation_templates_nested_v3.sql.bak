insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Supply Chain', 'تقييم كفاءة سلسلة الإمداد والمخزون', '{"version":3,"title_en":"Supply Chain and Inventory Efficiency Evaluation","title_ar":"تقييم كفاءة سلسلة الإمداد والمخزون","categories":[{"title_ar":"سلاسل الإمداد","criteria":[{"title_ar":"دقة التنبؤ بالطلب وإدارة المخزون","questions":[{"id":"q1","text":"إلى أي مدى يتطابق الجرد الفعلي للمخزون مع البيانات المسجلة في النظام التقني؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"إلى أي مدى يتطابق الجرد الفعلي للمخزون مع البيانات المسجلة في النظام التقني؟","text_en":""},{"id":"q3","text":"هل تتوفر متطلبات السلامة والتخزين السليمة (التهوية، الإضاءة، ترتيب الأرفف) في المستودع؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل تتوفر متطلبات السلامة والتخزين السليمة (التهوية، الإضاءة، ترتيب الأرفف) في المستودع؟","text_en":""},{"id":"q5","text":"صف حادثاً أو وشيك الوقوع (Near-miss) حدث مؤخراً في المستودع وكيف يمكن منعه مستقبلاً.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"صف حادثاً أو وشيك الوقوع (Near-miss) حدث مؤخراً في المستودع وكيف يمكن منعه مستقبلاً.","text_en":""},{"id":"q7","text":"هل تشعر أن صلاحيات الدخول والخروج للمستودع صارمة بما يكفي لمنع الفقد؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل تشعر أن صلاحيات الدخول والخروج للمستودع صارمة بما يكفي لمنع الفقد؟","text_en":""}]},{"title_ar":"زمن دورة التوريد من المورد إلى التسليم","questions":[{"id":"q2","text":"كيف تقيم سرعة وكفاءة عمليات الاستلام والتسليم داخل المستودع؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"كيف تقيم سرعة وكفاءة عمليات الاستلام والتسليم داخل المستودع؟","text_en":""},{"id":"q4","text":"قدم اقتراحاً واحداً للتحسين.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"قدم اقتراحاً واحداً للتحسين.","text_en":""},{"id":"q6","text":"هل يوجد إجراء واضح ومتبع باستمرار للتعامل مع المواد التالفة أو المتقادمة؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل يوجد إجراء واضح ومتبع باستمرار للتعامل مع المواد التالفة أو المتقادمة؟","text_en":""},{"id":"q8","text":"إذا كنا نهدف إلى تقليل الوقت المستغرق في تجهيز الطلبات بنسبة 50%، فما هو التغيير التقني أو المكاني الذي توصي به؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"إذا كنا نهدف إلى تقليل الوقت المستغرق في تجهيز الطلبات بنسبة 50%، فما هو التغيير التقني أو المكاني الذي توصي به؟","text_en":""}]}]}],"questions":[{"id":"q1","text":"إلى أي مدى يتطابق الجرد الفعلي للمخزون مع البيانات المسجلة في النظام التقني؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"إلى أي مدى يتطابق الجرد الفعلي للمخزون مع البيانات المسجلة في النظام التقني؟","text_en":"","category_ar":"سلاسل الإمداد","section_ar":"سلاسل الإمداد","criterion_ar":"دقة التنبؤ بالطلب وإدارة المخزون"},{"id":"q3","text":"هل تتوفر متطلبات السلامة والتخزين السليمة (التهوية، الإضاءة، ترتيب الأرفف) في المستودع؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل تتوفر متطلبات السلامة والتخزين السليمة (التهوية، الإضاءة، ترتيب الأرفف) في المستودع؟","text_en":"","category_ar":"سلاسل الإمداد","section_ar":"سلاسل الإمداد","criterion_ar":"دقة التنبؤ بالطلب وإدارة المخزون"},{"id":"q5","text":"صف حادثاً أو وشيك الوقوع (Near-miss) حدث مؤخراً في المستودع وكيف يمكن منعه مستقبلاً.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"صف حادثاً أو وشيك الوقوع (Near-miss) حدث مؤخراً في المستودع وكيف يمكن منعه مستقبلاً.","text_en":"","category_ar":"سلاسل الإمداد","section_ar":"سلاسل الإمداد","criterion_ar":"دقة التنبؤ بالطلب وإدارة المخزون"},{"id":"q7","text":"هل تشعر أن صلاحيات الدخول والخروج للمستودع صارمة بما يكفي لمنع الفقد؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل تشعر أن صلاحيات الدخول والخروج للمستودع صارمة بما يكفي لمنع الفقد؟","text_en":"","category_ar":"سلاسل الإمداد","section_ar":"سلاسل الإمداد","criterion_ar":"دقة التنبؤ بالطلب وإدارة المخزون"},{"id":"q2","text":"كيف تقيم سرعة وكفاءة عمليات الاستلام والتسليم داخل المستودع؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"كيف تقيم سرعة وكفاءة عمليات الاستلام والتسليم داخل المستودع؟","text_en":"","category_ar":"سلاسل الإمداد","section_ar":"سلاسل الإمداد","criterion_ar":"زمن دورة التوريد من المورد إلى التسليم"},{"id":"q4","text":"قدم اقتراحاً واحداً للتحسين.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"قدم اقتراحاً واحداً للتحسين.","text_en":"","category_ar":"سلاسل الإمداد","section_ar":"سلاسل الإمداد","criterion_ar":"زمن دورة التوريد من المورد إلى التسليم"},{"id":"q6","text":"هل يوجد إجراء واضح ومتبع باستمرار للتعامل مع المواد التالفة أو المتقادمة؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل يوجد إجراء واضح ومتبع باستمرار للتعامل مع المواد التالفة أو المتقادمة؟","text_en":"","category_ar":"سلاسل الإمداد","section_ar":"سلاسل الإمداد","criterion_ar":"زمن دورة التوريد من المورد إلى التسليم"},{"id":"q8","text":"إذا كنا نهدف إلى تقليل الوقت المستغرق في تجهيز الطلبات بنسبة 50%، فما هو التغيير التقني أو المكاني الذي توصي به؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"إذا كنا نهدف إلى تقليل الوقت المستغرق في تجهيز الطلبات بنسبة 50%، فما هو التغيير التقني أو المكاني الذي توصي به؟","text_en":"","category_ar":"سلاسل الإمداد","section_ar":"سلاسل الإمداد","criterion_ar":"زمن دورة التوريد من المورد إلى التسليم"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم كفاءة سلسلة الإمداد والمخزون'
);

