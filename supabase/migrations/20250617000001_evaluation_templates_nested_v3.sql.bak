اً من الجمهور مؤخراً، وما هو اقتراحك للحل الجذري؟","text_en":""},{"id":"q6","text":"هل تساعد قواعد البيانات وأنظمة الاتصال الحالية في الوصول إلى معلومات العميل بسرعة؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل تساعد قواعد البيانات وأنظمة الاتصال الحالية في الوصول إلى معلومات العميل بسرعة؟","text_en":""}]}]}],"questions":[{"id":"q1","text":"ما مدى سرعة استجابة الفريق لاستفسارات وشكاوى العملاء عبر القنوات المختلفة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"ما مدى سرعة استجابة الفريق لاستفسارات وشكاوى العملاء عبر القنوات المختلفة؟","text_en":"","category_ar":"تجربة العميل","section_ar":"تجربة العميل","criterion_ar":"رضا العملاء عن نقاط التواصل"},{"id":"q3","text":"صف موقفاً قدم فيه أحد الموظفين خدمة استثنائية لعميل.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"صف موقفاً قدم فيه أحد الموظفين خدمة استثنائية لعميل.","text_en":"","category_ar":"تجربة العميل","section_ar":"تجربة العميل","criterion_ar":"رضا العملاء عن نقاط التواصل"},{"id":"q5","text":"هل يمتلك موظفو خدمة العملاء الصلاحيات الكافية لحل مشاكل العملاء دون الرجوع الدائم للإدارة؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل يمتلك موظفو خدمة العملاء الصلاحيات الكافية لحل مشاكل العملاء دون الرجوع الدائم للإدارة؟","text_en":"","category_ar":"تجربة العميل","section_ar":"تجربة العميل","criterion_ar":"رضا العملاء عن نقاط التواصل"},{"id":"q7","text":"إذا أردنا تحويل كل عميل غير راضٍ إلى مدافع وموالٍ لنا، فما هي الأداة أو المهارة التي يجب أن نوفرها للفريق فوراً؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"إذا أردنا تحويل كل عميل غير راضٍ إلى مدافع وموالٍ لنا، فما هي الأداة أو المهارة التي يجب أن نوفرها للفريق فوراً؟","text_en":"","category_ar":"تجربة العميل","section_ar":"تجربة العميل","criterion_ar":"رضا العملاء عن نقاط التواصل"},{"id":"q2","text":"كيف تقيم قدرة موظفي الخطوط الأمامية على الحفاظ على الهدوء والاحترافية عند التعامل مع العملاء الغاضبين؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"كيف تقيم قدرة موظفي الخطوط الأمامية على الحفاظ على الهدوء والاحترافية عند التعامل مع العملاء الغاضبين؟","text_en":"","category_ar":"تجربة العميل","section_ar":"تجربة العميل","criterion_ar":"سرعة الاستجابة للشكاوى والاستفسارات"},{"id":"q4","text":"ما هي الشكوى الأكثر تكراراً من الجمهور مؤخراً، وما هو اقتراحك للحل الجذري؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"ما هي الشكوى الأكثر تكراراً من الجمهور مؤخراً، وما هو اقتراحك للحل الجذري؟","text_en":"","category_ar":"تجربة العميل","section_ar":"تجربة العميل","criterion_ar":"سرعة الاستجابة للشكاوى والاستفسارات"},{"id":"q6","text":"هل تساعد قواعد البيانات وأنظمة الاتصال الحالية في الوصول إلى معلومات العميل بسرعة؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل تساعد قواعد البيانات وأنظمة الاتصال الحالية في الوصول إلى معلومات العميل بسرعة؟","text_en":"","category_ar":"تجربة العميل","section_ar":"تجربة العميل","criterion_ar":"سرعة الاستجابة للشكاوى والاستفسارات"}]}'::jsonb
