select 'HR', 'تقييم جودة خدمات الموارد البشرية', '{"version":3,"title_en":"HR Service Quality Evaluation","title_ar":"تقييم جودة خدمات الموارد البشرية","categories":[{"title_ar":"جودة الخدمات","criteria":[{"title_ar":"سرعة الاستجابة لطلبات الموظفين","questions":[{"id":"q1","text":"ما مدى سهولة وسرعة تواصلك مع قسم الموارد البشرية عند وجود استفسار أو مشكلة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"ما مدى سهولة وسرعة تواصلك مع قسم الموارد البشرية عند وجود استفسار أو مشكلة؟","text_en":""},{"id":"q3","text":"يرجى ذكر مبادرة واحدة قام بها قسم الموارد البشرية أدت إلى تحسين روح الفريق أو إنتاجيتك.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"يرجى ذكر مبادرة واحدة قام بها قسم الموارد البشرية أدت إلى تحسين روح الفريق أو إنتاجيتك.","text_en":""},{"id":"q5","text":"هل تشعر أن الدورات التدريبية المقدمة من المنشأة تتوافق مع مسارك المهني الفعلي؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل تشعر أن الدورات التدريبية المقدمة من المنشأة تتوافق مع مسارك المهني الفعلي؟","text_en":""},{"id":"q7","text":"إذا طُلب منك تقييم ''عدالة التعامل'' داخل المنشأة من 0 إلى 10، فما الرقم الذي ستختاره؟","type":"rating_0_10","min":0,"max":10,"ratingHint":"طريقة التقييم: مقياس من 0 إلى 10","text_ar":"إذا طُلب منك تقييم ''عدالة التعامل'' داخل المنشأة من 0 إلى 10، فما الرقم الذي ستختاره؟","text_en":""}]},{"title_ar":"رضا الموظفين عن خدمات الموارد البشرية","questions":[{"id":"q2","text":"كيف تقيم وضوح إجراءات ''الترقيات'' و''الزيادات السنوية'' داخل المنشأة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"كيف تقيم وضوح إجراءات ''الترقيات'' و''الزيادات السنوية'' داخل المنشأة؟","text_en":""},{"id":"q4","text":"ما هو الشيء الذي تشعر أنه مفقود في نظام ''الحوافز والمكافآت'' الحالي وتود إضافته؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"ما هو الشيء الذي تشعر أنه مفقود في نظام ''الحوافز والمكافآت'' الحالي وتود إضافته؟","text_en":""},{"id":"q6","text":"هل يتم إطلاعك بانتظام على تقييم أدائك ومناقشة نقاط القوة والضعف لديك؟","type":"boolean","min":1,"max":5,"ratingHint":"طريقة التقييم: نعم / لا","text_ar":"هل يتم إطلاعك بانتظام على تقييم أدائك ومناقشة نقاط القوة والضعف لديك؟","text_en":""}]}]}],"questions":[{"id":"q1","text":"ما مدى سهولة وسرعة تواصلك مع قسم الموارد البشرية عند وجود استفسار أو مشكلة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"ما مدى سهولة وسرعة تواصلك مع قسم الموارد البشرية عند وجود استفسار أو مشكلة؟","text_en":"","category_ar":"جودة الخدمات","section_ar":"جودة الخدمات","criterion_ar":"سرعة الاستجابة لطلبات الموظفين"},{"id":"q3","text":"يرجى ذكر مبادرة واحدة قام بها قسم الموارد البشرية أدت إلى تحسين روح الفريق أو إنتاجيتك.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"يرجى ذكر مبادرة واحدة قام بها قسم الموارد البشرية أدت إلى تحسين روح الفريق أو إنتاجيتك.","text_en":"","category_ar":"جودة الخدمات","section_ar":"جودة الخدمات","criterion_ar":"سرعة الاستجابة لطلبات الموظفين"},{"id":"q5","text":"هل تشعر أن الدورات التدريبية المقدمة من المنشأة تتوافق مع مسارك المهني الفعلي؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل تشعر أن الدورات التدريبية المقدمة من المنشأة تتوافق مع مسارك المهني الفعلي؟","text_en":"","category_ar":"جودة الخدمات","section_ar":"جودة الخدمات","criterion_ar":"سرعة الاستجابة لطلبات الموظفين"},{"id":"q7","text":"إذا طُلب منك تقييم ''عدالة التعامل'' داخل المنشأة من 0 إلى 10، فما الرقم الذي ستختاره؟","type":"rating_0_10","min":0,"max":10,"ratingHint":"طريقة التقييم: مقياس من 0 إلى 10","text_ar":"إذا طُلب منك تقييم ''عدالة التعامل'' داخل المنشأة من 0 إلى 10، فما الرقم الذي ستختاره؟","text_en":"","category_ar":"جودة الخدمات","section_ar":"جودة الخدمات","criterion_ar":"سرعة الاستجابة لطلبات الموظفين"},{"id":"q2","text":"كيف تقيم وضوح إجراءات ''الترقيات'' و''الزيادات السنوية'' داخل المنشأة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"كيف تقيم وضوح إجراءات ''الترقيات'' و''الزيادات السنوية'' داخل المنشأة؟","text_en":"","category_ar":"جودة الخدمات","section_ar":"جودة الخدمات","criterion_ar":"رضا الموظفين عن خدمات الموارد البشرية"},{"id":"q4","text":"ما هو الشيء الذي تشعر أنه مفقود في نظام ''الحوافز والمكافآت'' الحالي وتود إضافته؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"ما هو الشيء الذي تشعر أنه مفقود في نظام ''الحوافز والمكافآت'' الحالي وتود إضافته؟","text_en":"","category_ar":"جودة الخدمات","section_ar":"جودة الخدمات","criterion_ar":"رضا الموظفين عن خدمات الموارد البشرية"},{"id":"q6","text":"هل يتم إطلاعك بانتظام على تقييم أدائك ومناقشة نقاط القوة والضعف لديك؟","type":"boolean","min":1,"max":5,"ratingHint":"طريقة التقييم: نعم / لا","text_ar":"هل يتم إطلاعك بانتظام على تقييم أدائك ومناقشة نقاط القوة والضعف لديك؟","text_en":"","category_ar":"جودة الخدمات","section_ar":"جودة الخدمات","criterion_ar":"رضا الموظفين عن خدمات الموارد البشرية"}]}'::jsonb
