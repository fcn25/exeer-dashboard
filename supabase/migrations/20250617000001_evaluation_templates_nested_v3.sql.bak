insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Procurement', 'تقييم كفاءة المشتريات وسلاسل الإمداد', '{"version":3,"title_en":"Procurement and Supply Chain Efficiency Evaluation","title_ar":"تقييم كفاءة المشتريات وسلاسل الإمداد","categories":[{"title_ar":"معايير التقييم","criteria":[{"title_ar":"أسئلة التقييم","questions":[{"id":"q1","type":"rating_0_100","text_en":"How quickly does procurement management fulfill purchase requests from your department since approval?","text_ar":"ما مدى سرعة إدارة المشتريات في تلبية طلبات الشراء الخاصة بقسمك بعد الموافقة عليها؟"},{"id":"q2","type":"rating_1_5","text_en":"How would you rate the quality of supplied materials or services compared to the specifications requested in the purchase order?","text_ar":"كيف تقيم جودة المواد أو الخدمات الموردة مقارنة بالمواصفات المطلوبة في أمر الشراء؟"},{"id":"q3","type":"text","text_en":"Have you experienced repeated operational downtime due to delays from a specific supplier? Please describe the situation and how it was handled.","text_ar":"هل واجهت تعطلاً تشغيلياً متكرراً بسبب تأخير من مورد معين؟ يرجى وصف الموقف وكيف تم التعامل معه."},{"id":"q4","type":"text","text_en":"Provide one suggestion to simplify the process of approving new suppliers to ensure better pricing and quality.","text_ar":"قدم اقتراحاً لتبسيط عملية اعتماد موردين جدد لضمان أسعار وجودة أفضل."},{"id":"q5","type":"choice","options_en":["Yes","No","Requires legal review"],"options_ar":["نعم","لا","تتطلب مراجعة قانونية"],"text_en":"Do you feel that contracts with current service providers adequately protect the organization''s rights?","text_ar":"هل تشعر أن العقود مع مقدمي الخدمات الحاليين تحمي حقوق المنشأة بشكل كافٍ؟"},{"id":"q6","type":"choice","options_en":["Yes","No"],"options_ar":["نعم","لا"],"text_en":"Are you regularly informed about renewal or expiration dates of contracts related to your department?","text_ar":"هل يتم إبلاغك بانتظام بتواريخ تجديد أو انتهاء العقود المتعلقة بقسمك؟"},{"id":"q7","type":"text","text_en":"If asked to propose a mechanism to reduce annual procurement costs by 10% without compromising quality, what would it be?","text_ar":"إذا طُلب منك اقتراح آلية لتقليل تكاليف المشتريات السنوية بنسبة 10% دون المساس بالجودة، فماذا ستكون؟"}]}]}],"questions":[{"id":"q1","type":"rating_0_100","text_en":"How quickly does procurement management fulfill purchase requests from your department since approval?","text_ar":"ما مدى سرعة إدارة المشتريات في تلبية طلبات الشراء الخاصة بقسمك بعد الموافقة عليها؟","category_ar":"معايير التقييم","section_ar":"معايير التقييم","criterion_ar":"أسئلة التقييم"},{"id":"q2","type":"rating_1_5","text_en":"How would you rate the quality of supplied materials or services compared to the specifications requested in the purchase order?","text_ar":"كيف تقيم جودة المواد أو الخدمات الموردة مقارنة بالمواصفات المطلوبة في أمر الشراء؟","category_ar":"معايير التقييم","section_ar":"معايير التقييم","criterion_ar":"أسئلة التقييم"},{"id":"q3","type":"text","text_en":"Have you experienced repeated operational downtime due to delays from a specific supplier? Please describe the situation and how it was handled.","text_ar":"هل واجهت تعطلاً تشغيلياً متكرراً بسبب تأخير من مورد معين؟ يرجى وصف الموقف وكيف تم التعامل معه.","category_ar":"معايير التقييم","section_ar":"معايير التقييم","criterion_ar":"أسئلة التقييم"},{"id":"q4","type":"text","text_en":"Provide one suggestion to simplify the process of approving new suppliers to ensure better pricing and quality.","text_ar":"قدم اقتراحاً لتبسيط عملية اعتماد موردين جدد لضمان أسعار وجودة أفضل.","category_ar":"معايير التقييم","section_ar":"معايير التقييم","criterion_ar":"أسئلة التقييم"},{"id":"q5","type":"choice","options_en":["Yes","No","Requires legal review"],"options_ar":["نعم","لا","تتطلب مراجعة قانونية"],"text_en":"Do you feel that contracts with current service providers adequately protect the organization''s rights?","text_ar":"هل تشعر أن العقود مع مقدمي الخدمات الحاليين تحمي حقوق المنشأة بشكل كافٍ؟","category_ar":"معايير التقييم","section_ar":"معايير التقييم","criterion_ar":"أسئلة التقييم"},{"id":"q6","type":"choice","options_en":["Yes","No"],"options_ar":["نعم","لا"],"text_en":"Are you regularly informed about renewal or expiration dates of contracts related to your department?","text_ar":"هل يتم إبلاغك بانتظام بتواريخ تجديد أو انتهاء العقود المتعلقة بقسمك؟","category_ar":"معايير التقييم","section_ar":"معايير التقييم","criterion_ar":"أسئلة التقييم"},{"id":"q7","type":"text","text_en":"If asked to propose a mechanism to reduce annual procurement costs by 10% without compromising quality, what would it be?","text_ar":"إذا طُلب منك اقتراح آلية لتقليل تكاليف المشتريات السنوية بنسبة 10% دون المساس بالجودة، فماذا ستكون؟","category_ar":"معايير التقييم","section_ar":"معايير التقييم","criterion_ar":"أسئلة التقييم"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم كفاءة المشتريات وسلاسل الإمداد'
);

update public.evaluation_templates
set category = 'Procurement',
    questions_jsonb = '{"version":3,"title_en":"Procurement and Supply Chain Efficiency Evaluation","title_ar":"تقييم كفاءة المشتريات وسلاسل الإمداد","categories":[{"title_ar":"معايير التقييم","criteria":[{"title_ar":"أسئلة التقييم","questions":[{"id":"q1","type":"rating_0_100","text_en":"How quickly does procurement management fulfill purchase requests from your department since approval?","text_ar":"ما مدى سرعة إدارة المشتريات في تلبية طلبات الشراء الخاصة بقسمك بعد الموافقة عليها؟"},{"id":"q2","type":"rating_1_5","text_en":"How would you rate the quality of supplied materials or services compared to the specifications requested in the purchase order?","text_ar":"كيف تقيم جودة المواد أو الخدمات الموردة مقارنة بالمواصفات المطلوبة في أمر الشراء؟"},{"id":"q3","type":"text","text_en":"Have you experienced repeated operational downtime due to delays from a specific supplier? Please describe the situation and how it was handled.","text_ar":"هل واجهت تعطلاً تشغيلياً متكرراً بسبب تأخير من مورد معين؟ يرجى وصف الموقف وكيف تم التعامل معه."},{"id":"q4","type":"text","text_en":"Provide one suggestion to simplify the process of approving new suppliers to ensure better pricing and quality.","text_ar":"قدم اقتراحاً لتبسيط عملية اعتماد موردين جدد لضمان أسعار وجودة أفضل."},{"id":"q5","type":"choice","options_en":["Yes","No","Requires legal review"],"options_ar":["نعم","لا","تتطلب مراجعة قانونية"],"text_en":"Do you feel that contracts with current service providers adequately protect the organization''s rights?","text_ar":"هل تشعر أن العقود مع مقدمي الخدمات الحاليين تحمي حقوق المنشأة بشكل كافٍ؟"},{"id":"q6","type":"choice","options_en":["Yes","No"],"options_ar":["نعم","لا"],"text_en":"Are you regularly informed about renewal or expiration dates of contracts related to your department?","text_ar":"هل يتم إبلاغك بانتظام بتواريخ تجديد أو انتهاء العقود المتعلقة بقسمك؟"},{"id":"q7","type":"text","text_en":"If asked to propose a mechanism to reduce annual procurement costs by 10% without compromising quality, what would it be?","text_ar":"إذا طُلب منك اقتراح آلية لتقليل تكاليف المشتريات السنوية بنسبة 10% دون المساس بالجودة، فماذا ستكون؟"}]}]}],"questions":[{"id":"q1","type":"rating_0_100","text_en":"How quickly does procurement management fulfill purchase requests from your department since approval?","text_ar":"ما مدى سرعة إدارة المشتريات في تلبية طلبات الشراء الخاصة بقسمك بعد الموافقة عليها؟","category_ar":"معايير التقييم","section_ar":"معايير التقييم","criterion_ar":"أسئلة التقييم"},{"id":"q2","type":"rating_1_5","text_en":"How would you rate the quality of supplied materials or services compared to the specifications requested in the purchase order?","text_ar":"كيف تقيم جودة المواد أو الخدمات الموردة مقارنة بالمواصفات المطلوبة في أمر الشراء؟","category_ar":"معايير التقييم","section_ar":"معايير التقييم","criterion_ar":"أسئلة التقييم"},{"id":"q3","type":"text","text_en":"Have you experienced repeated operational downtime due to delays from a specific supplier? Please describe the situation and how it was handled.","text_ar":"هل واجهت تعطلاً تشغيلياً متكرراً بسبب تأخير من مورد معين؟ يرجى وصف الموقف وكيف تم التعامل معه.","category_ar":"معايير التقييم","section_ar":"معايير التقييم","criterion_ar":"أسئلة التقييم"},{"id":"q4","type":"text","text_en":"Provide one suggestion to simplify the process of approving new suppliers to ensure better pricing and quality.","text_ar":"قدم اقتراحاً لتبسيط عملية اعتماد موردين جدد لضمان أسعار وجودة أفضل.","category_ar":"معايير التقييم","section_ar":"معايير التقييم","criterion_ar":"أسئلة التقييم"},{"id":"q5","type":"choice","options_en":["Yes","No","Requires legal review"],"options_ar":["نعم","لا","تتطلب مراجعة قانونية"],"text_en":"Do you feel that contracts with current service providers adequately protect the organization''s rights?","text_ar":"هل تشعر أن العقود مع مقدمي الخدمات الحاليين تحمي حقوق المنشأة بشكل كافٍ؟","category_ar":"معايير التقييم","section_ar":"معايير التقييم","criterion_ar":"أسئلة التقييم"},{"id":"q6","type":"choice","options_en":["Yes","No"],"options_ar":["نعم","لا"],"text_en":"Are you regularly informed about renewal or expiration dates of contracts related to your department?","text_ar":"هل يتم إبلاغك بانتظام بتواريخ تجديد أو انتهاء العقود المتعلقة بقسمك؟","category_ar":"معايير التقييم","section_ar":"معايير التقييم","criterion_ar":"أسئلة التقييم"},{"id":"q7","type":"text","text_en":"If asked to propose a mechanism to reduce annual procurement costs by 10% without compromising quality, what would it be?","text_ar":"إذا طُلب منك اقتراح آلية لتقليل تكاليف المشتريات السنوية بنسبة 10% دون المساس بالجودة، فماذا ستكون؟","category_ar":"معايير التقييم","section_ar":"معايير التقييم","criterion_ar":"أسئلة التقييم"}]}'::jsonb
where title = 'تقييم كفاءة المشتريات وسلاسل الإمداد';


insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Marketing', 'تقييم قوة العلامة التجارية وفعالية التسويق', '{"version":3,"title_en":"Brand Strength and Marketing Effectiveness Evaluation","title_ar":"تقييم قوة العلامة التجارية وفعالية التسويق","categories":[{"title_ar":"العلامة والتسويق","criteria":[{"title_ar":"وضوح رسالة العلامة التجارية","questions":[{"id":"q1","text":"إلى أي مدى تشعر أن الهوية البصرية للمنشأة تعكس قيمها الحقيقية؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"إلى أي مدى تشعر أن الهوية البصرية للمنشأة تعكس قيمها الحقيقية؟","text_en":""},{"id":"q3","text":"ما هي القناة التسويقية (سوشيال ميديا، إعلانات، علاقات عامة) التي تعتقد أنها الأكثر فعالية حالياً في جذب العملاء، ولماذا؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"ما هي القناة التسويقية (سوشيال ميديا، إعلانات، علاقات عامة) التي تعتقد أنها الأكثر فعالية حالياً في جذب العملاء، ولماذا؟","text_en":""},{"id":"q5","text":"هل تشعر أن حملاتنا التسويقية الحالية تتفوق على المنافسين المباشرين في السوق؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل تشعر أن حملاتنا التسويقية الحالية تتفوق على المنافسين المباشرين في السوق؟","text_en":""},{"id":"q7","text":"إذا كان لدينا ميزانية تسويق مفتوحة لشهر واحد، فما هي المبادرة الإبداعية التي ستقترحها لزيادة الوعي بالعلامة التجارية؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"إذا كان لدينا ميزانية تسويق مفتوحة لشهر واحد، فما هي المبادرة الإبداعية التي ستقترحها لزيادة الوعي بالعلامة التجارية؟","text_en":""}]},{"title_ar":"فعالية الحملات التسويقية على التحويل","questions":[{"id":"q2","text":"ما مدى سهولة شرحك لخدمات/منتجات المنشأة لشخص غريب بناءً على المواد التسويقية المتاحة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"ما مدى سهولة شرحك لخدمات/منتجات المنشأة لشخص غريب بناءً على المواد التسويقية المتاحة؟","text_en":""},{"id":"q4","text":"ما هو الانطباع الأول الذي يتركه اسم المنشأة في ذهن العميل عند سماعه لأول مرة؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"ما هو الانطباع الأول الذي يتركه اسم المنشأة في ذهن العميل عند سماعه لأول مرة؟","text_en":""},{"id":"q6","text":"هل يتم تزويدك بانتظام بمواد ترويجية محدثة لدعم عملك؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل يتم تزويدك بانتظام بمواد ترويجية محدثة لدعم عملك؟","text_en":""}]}]}],"questions":[{"id":"q1","text":"إلى أي مدى تشعر أن الهوية البصرية للمنشأة تعكس قيمها الحقيقية؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"إلى أي مدى تشعر أن الهوية البصرية للمنشأة تعكس قيمها الحقيقية؟","text_en":"","category_ar":"العلامة والتسويق","section_ar":"العلامة والتسويق","criterion_ar":"وضوح رسالة العلامة التجارية"},{"id":"q3","text":"ما هي القناة التسويقية (سوشيال ميديا، إعلانات، علاقات عامة) التي تعتقد أنها الأكثر فعالية حالياً في جذب العملاء، ولماذا؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"ما هي القناة التسويقية (سوشيال ميديا، إعلانات، علاقات عامة) التي تعتقد أنها الأكثر فعالية حالياً في جذب العملاء، ولماذا؟","text_en":"","category_ar":"العلامة والتسويق","section_ar":"العلامة والتسويق","criterion_ar":"وضوح رسالة العلامة التجارية"},{"id":"q5","text":"هل تشعر أن حملاتنا التسويقية الحالية تتفوق على المنافسين المباشرين في السوق؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل تشعر أن حملاتنا التسويقية الحالية تتفوق على المنافسين المباشرين في السوق؟","text_en":"","category_ar":"العلامة والتسويق","section_ar":"العلامة والتسويق","criterion_ar":"وضوح رسالة العلامة التجارية"},{"id":"q7","text":"إذا كان لدينا ميزانية تسويق مفتوحة لشهر واحد، فما هي المبادرة الإبداعية التي ستقترحها لزيادة الوعي بالعلامة التجارية؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"إذا كان لدينا ميزانية تسويق مفتوحة لشهر واحد، فما هي المبادرة الإبداعية التي ستقترحها لزيادة الوعي بالعلامة التجارية؟","text_en":"","category_ar":"العلامة والتسويق","section_ar":"العلامة والتسويق","criterion_ar":"وضوح رسالة العلامة التجارية"},{"id":"q2","text":"ما مدى سهولة شرحك لخدمات/منتجات المنشأة لشخص غريب بناءً على المواد التسويقية المتاحة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"ما مدى سهولة شرحك لخدمات/منتجات المنشأة لشخص غريب بناءً على المواد التسويقية المتاحة؟","text_en":"","category_ar":"العلامة والتسويق","section_ar":"العلامة والتسويق","criterion_ar":"فعالية الحملات التسويقية على التحويل"},{"id":"q4","text":"ما هو الانطباع الأول الذي يتركه اسم المنشأة في ذهن العميل عند سماعه لأول مرة؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"ما هو الانطباع الأول الذي يتركه اسم المنشأة في ذهن العميل عند سماعه لأول مرة؟","text_en":"","category_ar":"العلامة والتسويق","section_ar":"العلامة والتسويق","criterion_ar":"فعالية الحملات التسويقية على التحويل"},{"id":"q6","text":"هل يتم تزويدك بانتظام بمواد ترويجية محدثة لدعم عملك؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل يتم تزويدك بانتظام بمواد ترويجية محدثة لدعم عملك؟","text_en":"","category_ar":"العلامة والتسويق","section_ar":"العلامة والتسويق","criterion_ar":"فعالية الحملات التسويقية على التحويل"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم قوة العلامة التجارية وفعالية التسويق'
);

