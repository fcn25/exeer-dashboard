insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Strategy', 'تقييم النضج المؤسسي', '{"version":3,"title_en":"Institutional Maturity Assessment","title_ar":"تقييم النضج المؤسسي","categories":[{"title_ar":"الهيكلة والحوكمة","criteria":[{"title_ar":"مدى وضوح الهيكل التنظيمي وصلاحيات اتخاذ القرار","questions":[{"id":"q1","text":"إلى أي مدى تمتلك المنشأة خطة عمل واضحة ومعلنة للسنوات الثلاث القادمة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"إلى أي مدى تمتلك المنشأة خطة عمل واضحة ومعلنة للسنوات الثلاث القادمة؟","text_en":""}]},{"title_ar":"فعالية آليات الحوكمة والرقابة الداخلية","questions":[{"id":"q2","text":"اذكر أهم 3 عمليات روتينية تستهلك وقتاً كبيراً ويمكن أتمتتها أو تحسينها.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"اذكر أهم 3 عمليات روتينية تستهلك وقتاً كبيراً ويمكن أتمتتها أو تحسينها.","text_en":""}]},{"title_ar":"مستوى توثيق السياسات والإجراءات المؤسسية","questions":[{"id":"q3","text":"هل يمنع توزيع المهام والصلاحيات بين الأقسام تداخل القرارات؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل يمنع توزيع المهام والصلاحيات بين الأقسام تداخل القرارات؟","text_en":""}]}]},{"title_ar":"النضج الاستراتيجي","criteria":[{"title_ar":"اتساق الأهداف الاستراتيجية مع العمليات اليومية","questions":[{"id":"q4","text":"في رأيك، ما هي أكبر عقبة يمكن أن تهدد استدامة المنشأة في السوق اليوم؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"في رأيك، ما هي أكبر عقبة يمكن أن تهدد استدامة المنشأة في السوق اليوم؟","text_en":""}]},{"title_ar":"قدرة المنشأة على قياس ومراجعة الأداء المؤسسي","questions":[]}]}],"questions":[{"id":"q1","text":"إلى أي مدى تمتلك المنشأة خطة عمل واضحة ومعلنة للسنوات الثلاث القادمة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"إلى أي مدى تمتلك المنشأة خطة عمل واضحة ومعلنة للسنوات الثلاث القادمة؟","text_en":"","category_ar":"الهيكلة والحوكمة","section_ar":"الهيكلة والحوكمة","criterion_ar":"مدى وضوح الهيكل التنظيمي وصلاحيات اتخاذ القرار"},{"id":"q2","text":"اذكر أهم 3 عمليات روتينية تستهلك وقتاً كبيراً ويمكن أتمتتها أو تحسينها.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"اذكر أهم 3 عمليات روتينية تستهلك وقتاً كبيراً ويمكن أتمتتها أو تحسينها.","text_en":"","category_ar":"الهيكلة والحوكمة","section_ar":"الهيكلة والحوكمة","criterion_ar":"فعالية آليات الحوكمة والرقابة الداخلية"},{"id":"q3","text":"هل يمنع توزيع المهام والصلاحيات بين الأقسام تداخل القرارات؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل يمنع توزيع المهام والصلاحيات بين الأقسام تداخل القرارات؟","text_en":"","category_ar":"الهيكلة والحوكمة","section_ar":"الهيكلة والحوكمة","criterion_ar":"مستوى توثيق السياسات والإجراءات المؤسسية"},{"id":"q4","text":"في رأيك، ما هي أكبر عقبة يمكن أن تهدد استدامة المنشأة في السوق اليوم؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"في رأيك، ما هي أكبر عقبة يمكن أن تهدد استدامة المنشأة في السوق اليوم؟","text_en":"","category_ar":"النضج الاستراتيجي","section_ar":"النضج الاستراتيجي","criterion_ar":"اتساق الأهداف الاستراتيجية مع العمليات اليومية"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم النضج المؤسسي'
);

