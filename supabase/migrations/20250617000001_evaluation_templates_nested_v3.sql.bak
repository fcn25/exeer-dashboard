update public.evaluation_templates
set category = 'Technology',
    questions_jsonb = '{"version":3,"title_en":"Digital Readiness and AI Assessment","title_ar":"تقييم الجاهزية الرقمية والذكاء الاصطناعي","categories":[{"title_ar":"الجاهزية الرقمية","criteria":[{"title_ar":"نضج الأنظمة الرقمية الأساسية","questions":[{"id":"q1","text":"ما مدى وعيك بأدوات الذكاء الاصطناعي التي يمكن أن تساعدك في مهامك اليومية؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"ما مدى وعيك بأدوات الذكاء الاصطناعي التي يمكن أن تساعدك في مهامك اليومية؟","text_en":""}]},{"title_ar":"أمن المعلومات وحماية البيانات","questions":[{"id":"q2","text":"ما هي المهارة التقنية التي تشعر أنك بحاجة إلى تدريب مكثف عليها لتصبح أكثر إنتاجية؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"ما هي المهارة التقنية التي تشعر أنك بحاجة إلى تدريب مكثف عليها لتصبح أكثر إنتاجية؟","text_en":""}]}]},{"title_ar":"الذكاء الاصطناعي","criteria":[{"title_ar":"مدى استخدام أدوات الذكاء الاصطناعي في العمليات","questions":[{"id":"q3","text":"هل تؤيد استبدال بعض المهام اليدوية المتكررة ببرامج ذكية، حتى لو تطلب ذلك تغيير طبيعة عملك؟","type":"boolean","min":1,"max":5,"ratingHint":"طريقة التقييم: نعم / لا","text_ar":"هل تؤيد استبدال بعض المهام اليدوية المتكررة ببرامج ذكية، حتى لو تطلب ذلك تغيير طبيعة عملك؟","text_en":""}]},{"title_ar":"جاهزية الفريق للتبني التدريجي للتقنيات","questions":[{"id":"q4","text":"اقترح مهمة واحدة في قسمك تعتقد أنه يجب على نظام ''إكسير'' أتمتتها فوراً.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"اقترح مهمة واحدة في قسمك تعتقد أنه يجب على نظام ''إكسير'' أتمتتها فوراً.","text_en":""}]}]}],"questions":[{"id":"q1","text":"ما مدى وعيك بأدوات الذكاء الاصطناعي التي يمكن أن تساعدك في مهامك اليومية؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"ما مدى وعيك بأدوات الذكاء الاصطناعي التي يمكن أن تساعدك في مهامك اليومية؟","text_en":"","category_ar":"الجاهزية الرقمية","section_ar":"الجاهزية الرقمية","criterion_ar":"نضج الأنظمة الرقمية الأساسية"},{"id":"q2","text":"ما هي المهارة التقنية التي تشعر أنك بحاجة إلى تدريب مكثف عليها لتصبح أكثر إنتاجية؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"ما هي المهارة التقنية التي تشعر أنك بحاجة إلى تدريب مكثف عليها لتصبح أكثر إنتاجية؟","text_en":"","category_ar":"الجاهزية الرقمية","section_ar":"الجاهزية الرقمية","criterion_ar":"أمن المعلومات وحماية البيانات"},{"id":"q3","text":"هل تؤيد استبدال بعض المهام اليدوية المتكررة ببرامج ذكية، حتى لو تطلب ذلك تغيير طبيعة عملك؟","type":"boolean","min":1,"max":5,"ratingHint":"طريقة التقييم: نعم / لا","text_ar":"هل تؤيد استبدال بعض المهام اليدوية المتكررة ببرامج ذكية، حتى لو تطلب ذلك تغيير طبيعة عملك؟","text_en":"","category_ar":"الذكاء الاصطناعي","section_ar":"الذكاء الاصطناعي","criterion_ar":"مدى استخدام أدوات الذكاء الاصطناعي في العمليات"},{"id":"q4","text":"اقترح مهمة واحدة في قسمك تعتقد أنه يجب على نظام ''إكسير'' أتمتتها فوراً.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"اقترح مهمة واحدة في قسمك تعتقد أنه يجب على نظام ''إكسير'' أتمتتها فوراً.","text_en":"","category_ar":"الذكاء الاصطناعي","section_ar":"الذكاء الاصطناعي","criterion_ar":"جاهزية الفريق للتبني التدريجي للتقنيات"}]}'::jsonb
where title = 'تقييم الجاهزية الرقمية والذكاء الاصطناعي';


insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Sales', 'تقييم فعالية فريق المبيعات', '{"version":3,"title_en":"Sales Team Effectiveness Evaluation","title_ar":"تقييم فعالية فريق المبيعات","categories":[{"title_ar":"فعالية المبيعات","criteria":[{"title_ar":"تحقيق أهداف المبيعات الشهرية/الربع سنوية","questions":[{"id":"q1","text":"ما مدى رضاك عن تحقيقك لهدف المبيعات الخاص بك خلال الفترة الماضية؟","type":"rating_0_10","min":0,"max":10,"ratingHint":"طريقة التقييم: مقياس من 0 إلى 10","text_ar":"ما مدى رضاك عن تحقيقك لهدف المبيعات الخاص بك خلال الفترة الماضية؟","text_en":""},{"id":"q3","text":"ما هو أكبر اعتراض واجهته مؤخراً من العملاء، وكيف تعاملت معه لإتمام الصفقة؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"ما هو أكبر اعتراض واجهته مؤخراً من العملاء، وكيف تعاملت معه لإتمام الصفقة؟","text_en":""},{"id":"q5","text":"هل تشعر أن سياسة التسعير الحالية للمنتجات/الخدمات تنافسية في السوق؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل تشعر أن سياسة التسعير الحالية للمنتجات/الخدمات تنافسية في السوق؟","text_en":""},{"id":"q7","text":"لو كنت مدير المبيعات ليوم واحد، ما هو التغيير الوحيد الذي ستحدثه في عملية المبيعات لزيادة الإيرادات بنسبة 20%؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"لو كنت مدير المبيعات ليوم واحد، ما هو التغيير الوحيد الذي ستحدثه في عملية المبيعات لزيادة الإيرادات بنسبة 20%؟","text_en":""}]},{"title_ar":"جودة pipeline وإغلاق الصفقات","questions":[{"id":"q2","text":"كيف تقيم جودة العملاء المحتملين (Leads) المقدمين لك من قبل المنشأة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"كيف تقيم جودة العملاء المحتملين (Leads) المقدمين لك من قبل المنشأة؟","text_en":""},{"id":"q4","text":"يرجى ذكر مهارة واحدة (مثل: التفاوض، الإغلاق، العرض) تشعر أنك بحاجة لتطويرها لزيادة أدائك البيعي.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"يرجى ذكر مهارة واحدة (مثل: التفاوض، الإغلاق، العرض) تشعر أنك بحاجة لتطويرها لزيادة أدائك البيعي.","text_en":""},{"id":"q6","text":"هل تمتلك أدوات تقنية كافية لتتبع عملائك (مثل: نظام CRM أو تطبيقات تواصل)؟","type":"boolean","min":1,"max":5,"ratingHint":"طريقة التقييم: نعم / لا","text_ar":"هل تمتلك أدوات تقنية كافية لتتبع عملائك (مثل: نظام CRM أو تطبيقات تواصل)؟","text_en":""}]}]}],"questions":[{"id":"q1","text":"ما مدى رضاك عن تحقيقك لهدف المبيعات الخاص بك خلال الفترة الماضية؟","type":"rating_0_10","min":0,"max":10,"ratingHint":"طريقة التقييم: مقياس من 0 إلى 10","text_ar":"ما مدى رضاك عن تحقيقك لهدف المبيعات الخاص بك خلال الفترة الماضية؟","text_en":"","category_ar":"فعالية المبيعات","section_ar":"فعالية المبيعات","criterion_ar":"تحقيق أهداف المبيعات الشهرية/الربع سنوية"},{"id":"q3","text":"ما هو أكبر اعتراض واجهته مؤخراً من العملاء، وكيف تعاملت معه لإتمام الصفقة؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"ما هو أكبر اعتراض واجهته مؤخراً من العملاء، وكيف تعاملت معه لإتمام الصفقة؟","text_en":"","category_ar":"فعالية المبيعات","section_ar":"فعالية المبيعات","criterion_ar":"تحقيق أهداف المبيعات الشهرية/الربع سنوية"},{"id":"q5","text":"هل تشعر أن سياسة التسعير الحالية للمنتجات/الخدمات تنافسية في السوق؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل تشعر أن سياسة التسعير الحالية للمنتجات/الخدمات تنافسية في السوق؟","text_en":"","category_ar":"فعالية المبيعات","section_ar":"فعالية المبيعات","criterion_ar":"تحقيق أهداف المبيعات الشهرية/الربع سنوية"},{"id":"q7","text":"لو كنت مدير المبيعات ليوم واحد، ما هو التغيير الوحيد الذي ستحدثه في عملية المبيعات لزيادة الإيرادات بنسبة 20%؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"لو كنت مدير المبيعات ليوم واحد، ما هو التغيير الوحيد الذي ستحدثه في عملية المبيعات لزيادة الإيرادات بنسبة 20%؟","text_en":"","category_ar":"فعالية المبيعات","section_ar":"فعالية المبيعات","criterion_ar":"تحقيق أهداف المبيعات الشهرية/الربع سنوية"},{"id":"q2","text":"كيف تقيم جودة العملاء المحتملين (Leads) المقدمين لك من قبل المنشأة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"كيف تقيم جودة العملاء المحتملين (Leads) المقدمين لك من قبل المنشأة؟","text_en":"","category_ar":"فعالية المبيعات","section_ar":"فعالية المبيعات","criterion_ar":"جودة pipeline وإغلاق الصفقات"},{"id":"q4","text":"يرجى ذكر مهارة واحدة (مثل: التفاوض، الإغلاق، العرض) تشعر أنك بحاجة لتطويرها لزيادة أدائك البيعي.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"يرجى ذكر مهارة واحدة (مثل: التفاوض، الإغلاق، العرض) تشعر أنك بحاجة لتطويرها لزيادة أدائك البيعي.","text_en":"","category_ar":"فعالية المبيعات","section_ar":"فعالية المبيعات","criterion_ar":"جودة pipeline وإغلاق الصفقات"},{"id":"q6","text":"هل تمتلك أدوات تقنية كافية لتتبع عملائك (مثل: نظام CRM أو تطبيقات تواصل)؟","type":"boolean","min":1,"max":5,"ratingHint":"طريقة التقييم: نعم / لا","text_ar":"هل تمتلك أدوات تقنية كافية لتتبع عملائك (مثل: نظام CRM أو تطبيقات تواصل)؟","text_en":"","category_ar":"فعالية المبيعات","section_ar":"فعالية المبيعات","criterion_ar":"جودة pipeline وإغلاق الصفقات"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم فعالية فريق المبيعات'
);

