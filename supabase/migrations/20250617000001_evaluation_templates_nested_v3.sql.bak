ظيمي وصلاحيات اتخاذ القرار"},{"id":"q2","text":"اذكر أهم 3 عمليات روتينية تستهلك وقتاً كبيراً ويمكن أتمتتها أو تحسينها.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"اذكر أهم 3 عمليات روتينية تستهلك وقتاً كبيراً ويمكن أتمتتها أو تحسينها.","text_en":"","category_ar":"الهيكلة والحوكمة","section_ar":"الهيكلة والحوكمة","criterion_ar":"فعالية آليات الحوكمة والرقابة الداخلية"},{"id":"q3","text":"هل يمنع توزيع المهام والصلاحيات بين الأقسام تداخل القرارات؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل يمنع توزيع المهام والصلاحيات بين الأقسام تداخل القرارات؟","text_en":"","category_ar":"الهيكلة والحوكمة","section_ar":"الهيكلة والحوكمة","criterion_ar":"مستوى توثيق السياسات والإجراءات المؤسسية"},{"id":"q4","text":"في رأيك، ما هي أكبر عقبة يمكن أن تهدد استدامة المنشأة في السوق اليوم؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"في رأيك، ما هي أكبر عقبة يمكن أن تهدد استدامة المنشأة في السوق اليوم؟","text_en":"","category_ar":"النضج الاستراتيجي","section_ar":"النضج الاستراتيجي","criterion_ar":"اتساق الأهداف الاستراتيجية مع العمليات اليومية"}]}'::jsonb
where title = 'تقييم النضج المؤسسي';


