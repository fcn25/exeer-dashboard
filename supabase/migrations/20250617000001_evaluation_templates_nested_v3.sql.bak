insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Technology', 'تقييم الجاهزية الرقمية والذكاء الاصطناعي', '{"version":3,"title_en":"Digital Readiness and AI Assessment","title_ar":"تقييم الجاهزية الرقمية والذكاء الاصطناعي","categories":[{"title_ar":"الجاهزية الرقمية","criteria":[{"title_ar":"نضج الأنظمة الرقمية الأساسية","questions":[{"id":"q1","text":"ما مدى وعيك بأدوات الذكاء الاصطناعي التي يمكن أن تساعدك في مهامك اليومية؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"ما مدى وعيك بأدوات الذكاء الاصطناعي التي يمكن أن تساعدك في مهامك اليومية؟","text_en":""}]},{"title_ar":"أمن المعلومات وحماية البيانات","questions":[{"id":"q2","text":"ما هي المهارة التقنية التي تشعر أنك بحاجة إلى تدريب مكثف عليها لتصبح أكثر إنتاجية؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"ما هي المهارة التقنية التي تشعر أنك بحاجة إلى تدريب مكثف عليها لتصبح أكثر إنتاجية؟","text_en":""}]}]},{"title_ar":"الذكاء الاصطناعي","criteria":[{"title_ar":"مدى استخدام أدوات الذكاء الاصطناعي في العمليات","questions":[{"id":"q3","text":"هل تؤيد استبدال بعض المهام اليدوية المتكررة ببرامج ذكية، حتى لو تطلب ذلك تغيير طبيعة عملك؟","type":"boolean","min":1,"max":5,"ratingHint":"طريقة التقييم: نعم / لا","text_ar":"هل تؤيد استبدال بعض المهام اليدوية المتكررة ببرامج ذكية، حتى لو تطلب ذلك تغيير طبيعة عملك؟","text_en":""}]},{"title_ar":"جاهزية الفريق للتبني التدريجي للتقنيات","questions":[{"id":"q4","text":"اقترح مهمة واحدة في قسمك تعتقد أنه يجب على نظام ''إكسير'' أتمتتها فوراً.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"اقترح مهمة واحدة في قسمك تعتقد أنه يجب على نظام ''إكسير'' أتمتتها فوراً.","text_en":""}]}]}],"questions":[{"id":"q1","text":"ما مدى وعيك بأدوات الذكاء الاصطناعي التي يمكن أن تساعدك في مهامك اليومية؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"ما مدى وعيك بأدوات الذكاء الاصطناعي التي يمكن أن تساعدك في مهامك اليومية؟","text_en":"","category_ar":"الجاهزية الرقمية","sectio