insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Finance', 'تقييم الكفاءة المالية والامتثال', '{"version":3,"title_en":"Financial Efficiency and Compliance Evaluation","title_ar":"تقييم الكفاءة المالية والامتثال","categories":[{"title_ar":"الكفاءة المالية","criteria":[{"title_ar":"الالتزام بالميزانية والتكلفة لكل وحدة","questions":[{"id":"q1","text":"ما مدى رضاك عن سرعة معالجة الطلبات المالية (مثل: الإيداعات، المصروفات، أو المطالبات البنكية)؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"ما مدى رضاك عن سرعة معالجة الطلبات المالية (مثل: الإيداعات، المصروفات، أو المطالبات البنكية)؟","text_en":""},{"id":"q5","text":"هل تشعر أن السياسات المالية الحالية تساعد في حماية موارد المنشأة من الهدر؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل تشعر أن السياسات المالية الحالية تساعد في حماية موارد المنشأة من الهدر؟","text_en":""}]},{"title_ar":"دقة التقارير المالية ومواعيد إغلاقها","questions":[{"id":"q2","text":"كيف تقيم وضوح النماذج والطلبات المالية المطلوبة من قسمك لتنفيذ العمليات؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"كيف تقيم وضوح النماذج والطلبات المالية المطلوبة من قسمك لتنفيذ العمليات؟","text_en":""},{"id":"q6","text":"كيف تقيم دقة البيانات المالية التي تتم مشاركتها داخل قسمك؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"كيف تقيم دقة البيانات المالية التي تتم مشاركتها داخل قسمك؟","text_en":""}]}]},{"title_ar":"الامتثال","criteria":[{"title_ar":"الالتزام بالأنظمة واللوائح ذات الصلة","questions":[{"id":"q3","text":"هل يتم تزويدك بتقارير ميزانية دورية توضح المصروفات الفعلية مقابل المخطط لها؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل يتم تزويدك بتقارير ميزانية دورية توضح المصروفات الفعلية مقابل المخطط لها؟","text_en":""},{"id":"q7","text":"إذا كان بإمكانك أتمتة عملية مالية واحدة في المنشأة، فما هي؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"إذا كان بإمكانك أتمتة عملية مالية واحدة في المنشأة، فما هي؟","text_en":""}]},{"title_ar":"اكتمال مستندات التدقيق والمراجعة","questions":[{"id":"q4","text":"يرجى وصف تحدٍ واحد واجهته عند التعامل مع ''المحاسبة'' أو ''المراجعة الداخلية'' خلال الفترة الماضية.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"يرجى وصف تحدٍ واحد واجهته عند التعامل مع ''المحاسبة'' أو ''المراجعة الداخلية'' خلال الفترة الماضية.","text_en":""}]}]}],"questions":[{"id":"q1","text":"ما مدى رضاك عن سرعة معالجة الطلبات المالية (مثل: الإيداعات، المصروفات، أو المطالبات البنكية)؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"ما مدى رضاك عن سرعة معالجة الطلبات المالية (مثل: الإيداعات، المصروفات، أو المطالبات البنكية)؟","text_en":"","category_ar":"الكفاءة المالية","section_ar":"الكفاءة المالية","criterion_ar":"الالتزام بالميزانية والتكلفة لكل وحدة"},{"id":"q5","text":"هل تشعر أن السياسات المالية الحالية تساعد في حماية موارد المنشأة من الهدر؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل تشعر أن السياسات المالية الحالية تساعد في حماية موارد المنشأة من الهدر؟","text_en":"","category_ar":"الكفاءة المالية","section_ar":"الكفاءة المالية","criterion_ar":"الالتزام بالميزانية والتكلفة لكل وحدة"},{"id":"q2","text":"كيف تقيم وضوح النماذج والطلبات المالية المطلوبة من قسمك لتنفيذ العمليات؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"كيف تقيم وضوح النماذج والطلبات المالية المطلوبة من قسمك لتنفيذ العمليات؟","text_en":"","category_ar":"الكفاءة المالية","section_ar":"الكفاءة المالية","criterion_ar":"دقة التقارير المالية ومواعيد إغلاقها"},{"id":"q6","text":"كيف تقيم دقة البيانات المالية التي تتم مشاركتها داخل قسمك؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"كيف تقيم دقة البيانات المالية التي تتم مشاركتها داخل قسمك؟","text_en":"","category_ar":"الكفاءة المالية","section_ar":"الكفاءة المالية","criterion_ar":"دقة التقارير المالية ومواعيد إغلاقها"},{"id":"q3","text":"هل يتم تزويدك بتقارير ميزانية دورية توضح المصروفات الفعلية مقابل المخطط لها؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل يتم تزويدك بتقارير ميزانية دورية توضح المصروفات الفعلية مقابل المخطط لها؟","text_en":"","category_ar":"الامتثال","section_ar":"الامتثال","criterion_ar":"الالتزام بالأنظمة واللوائح ذات الصلة"},{"id":"q7","text":"إذا كان بإمكانك أتمتة عملية مالية واحدة في المنشأة، فما هي؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"إذا كان بإمكانك أتمتة عملية مالية واحدة في المنشأة، فما هي؟","text_en":"","category_ar":"الامتثال","section_ar":"الامتثال","criterion_ar":"الالتزام بالأنظمة واللوائح ذات الصلة"},{"id":"q4","text":"يرجى وصف تحدٍ واحد واجهته عند التعامل مع ''المحاسبة'' أو ''المراجعة الداخلية'' خلال الفترة الماضية.","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"يرجى وصف تحدٍ واحد واجهته عند التعامل مع ''المحاسبة'' أو ''المراجعة الداخلية'' خلال الفترة الماضية.","text_en":"","category_ar":"الامتثال","section_ar":"الامتثال","criterion_ar":"اكتمال مستندات التدقيق والمراجعة"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم الكفاءة المالية والامتثال'
);

