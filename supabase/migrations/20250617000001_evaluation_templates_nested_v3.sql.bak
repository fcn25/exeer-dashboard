n_ar":"التقييم الذاتي","criterion_ar":"المهارات التي تم تطويرها"},{"id":"q3","text":"ما هي التحديات التي واجهتها؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"ما هي التحديات التي واجهتها؟","text_en":"","category_ar":"التقييم الذاتي","section_ar":"التقييم الذاتي","criterion_ar":"مجالات التحسين الشخصي"}]}'::jsonb
