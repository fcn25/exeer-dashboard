insert into public.evaluation_templates (category, title, questions_jsonb)
select 'IT', 'تقييم البنية التحتية التقنية والدعم الفني', '{"version":3,"title_en":"IT Infrastructure and Support Evaluation","title_ar":"تقييم البنية التحتية التقنية والدعم الفني","categories":[{"title_ar":"البنية التقنية","criteria":[{"title_ar":"استقرار الأنظمة وتوفر الخدمة","questions":[{"id":"q1","text":"ما مدى سرعة استجابة فريق تقنية المعلومات عند فتح تذكرة لطلب المساعدة الفنية؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"ما مدى سرعة استجابة فريق تقنية المعلومات عند فتح تذكرة لطلب المساعدة الفنية؟","text_en":""},{"id":"q3","text":"ما هو البرنامج أو النظام في المنشأة الذي تعتقد أنه يحتاج بشكل عاجل إلى تحديث أو استبدال بسبب أعطاله المتكررة؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"ما هو البرنامج أو النظام في المنشأة الذي تعتقد أنه يحتاج بشكل عاجل إلى تحديث أو استبدال بسبب أعطاله المتكررة؟","text_en":""},{"id":"q5","text":"هل تشعر أن سرعة الإنترنت وتوفر الأجهزة المناسبة تتيح لك أداء عملك بأقصى كفاءة؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل تشعر أن سرعة الإنترنت وتوفر الأجهزة المناسبة تتيح لك أداء عملك بأقصى كفاءة؟","text_en":""},{"id":"q7","text":"إذا كان بإمكاننا التخلص من عملية ورقية واحدة في قسمك ورقمنتها بالكامل، فما هي؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"إذا كان بإمكاننا التخلص من عملية ورقية واحدة في قسمك ورقمنتها بالكامل، فما هي؟","text_en":""}]},{"title_ar":"زمن حل الحوادث التقنية","questions":[{"id":"q2","text":"كيف تقيم قدرة الفريق على حل المشاكل المتكررة بشكل جذري بدلاً من الحلول المؤقتة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"كيف تقيم قدرة الفريق على حل المشاكل المتكررة بشكل جذري بدلاً من الحلول المؤقتة؟","text_en":""},{"id":"q4","text":"صف الخطوات التي تتخذه عند مواجهة رسالة مشبوهة أو محاولة اختراق سيبراني (لتقييم الوعي الأمني).","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"صف الخطوات التي تتخذه عند مواجهة رسالة مشبوهة أو محاولة اختراق سيبراني (لتقييم الوعي الأمني).","text_en":""},{"id":"q6","text":"هل لديك صلاحيات وصول كافية للبيانات التي تحتاجها لعملك دون تعقيدات إدارية مفرطة؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل لديك صلاحيات وصول كافية للبيانات التي تحتاجها لعملك دون تعقيدات إدارية مفرطة؟","text_en":""}]}]}],"questions":[{"id":"q1","text":"ما مدى سرعة استجابة فريق تقنية المعلومات عند فتح تذكرة لطلب المساعدة الفنية؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"ما مدى سرعة استجابة فريق تقنية المعلومات عند فتح تذكرة لطلب المساعدة الفنية؟","text_en":"","category_ar":"البنية التقنية","section_ar":"البنية التقنية","criterion_ar":"استقرار الأنظمة وتوفر الخدمة"},{"id":"q3","text":"ما هو البرنامج أو النظام في المنشأة الذي تعتقد أنه يحتاج بشكل عاجل إلى تحديث أو استبدال بسبب أعطاله المتكررة؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"ما هو البرنامج أو النظام في المنشأة الذي تعتقد أنه يحتاج بشكل عاجل إلى تحديث أو استبدال بسبب أعطاله المتكررة؟","text_en":"","category_ar":"البنية التقنية","section_ar":"البنية التقنية","criterion_ar":"استقرار الأنظمة وتوفر الخدمة"},{"id":"q5","text":"هل تشعر أن سرعة الإنترنت وتوفر الأجهزة المناسبة تتيح لك أداء عملك بأقصى كفاءة؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل تشعر أن سرعة الإنترنت وتوفر الأجهزة المناسبة تتيح لك أداء عملك بأقصى كفاءة؟","text_en":"","category_ar":"البنية التقنية","section_ar":"البنية التقنية","criterion_ar":"استقرار الأنظمة وتوفر الخدمة"},{"id":"q7","text":"إذا كان بإمكاننا التخلص من عملية ورقية واحدة في قسمك ورقمنتها بالكامل، فما هي؟","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"إذا كان بإمكاننا التخلص من عملية ورقية واحدة في قسمك ورقمنتها بالكامل، فما هي؟","text_en":"","category_ar":"البنية التقنية","section_ar":"البنية التقنية","criterion_ar":"استقرار الأنظمة وتوفر الخدمة"},{"id":"q2","text":"كيف تقيم قدرة الفريق على حل المشاكل المتكررة بشكل جذري بدلاً من الحلول المؤقتة؟","type":"rating_1_5","min":1,"max":5,"ratingHint":"طريقة التقييم: مقياس من 1 إلى 5","text_ar":"كيف تقيم قدرة الفريق على حل المشاكل المتكررة بشكل جذري بدلاً من الحلول المؤقتة؟","text_en":"","category_ar":"البنية التقنية","section_ar":"البنية التقنية","criterion_ar":"زمن حل الحوادث التقنية"},{"id":"q4","text":"صف الخطوات التي تتخذه عند مواجهة رسالة مشبوهة أو محاولة اختراق سيبراني (لتقييم الوعي الأمني).","type":"text","min":1,"max":5,"ratingHint":"طريقة التقييم: إجابة نصية","text_ar":"صف الخطوات التي تتخذه عند مواجهة رسالة مشبوهة أو محاولة اختراق سيبراني (لتقييم الوعي الأمني).","text_en":"","category_ar":"البنية التقنية","section_ar":"البنية التقنية","criterion_ar":"زمن حل الحوادث التقنية"},{"id":"q6","text":"هل لديك صلاحيات وصول كافية للبيانات التي تحتاجها لعملك دون تعقيدات إدارية مفرطة؟","type":"choice","min":1,"max":5,"ratingHint":"طريقة التقييم: اختيار من قائمة","text_ar":"هل لديك صلاحيات وصول كافية للبيانات التي تحتاجها لعملك دون تعقيدات إدارية مفرطة؟","text_en":"","category_ar":"البنية التقنية","section_ar":"البنية التقنية","criterion_ar":"زمن حل الحوادث التقنية"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم البنية التحتية التقنية والدعم الفني'
);

