-- تقييم التنفيذيين ومدراء الأقسام
insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Management', 'تقييم التنفيذيين ومدراء الأقسام', '{"version":3,"title_en":"Executive and Department Head Evaluation","title_ar":"تقييم التنفيذيين ومدراء الأقسام","categories":[{"title_ar":"القيادة والتوجيه","criteria":[{"title_ar":"ما مدى وضوح الرؤية التي يقدمها المدير للفريق وربطها بالأهداف؟","questions":[{"id":"gm-1","type":"rating_1_5","text_ar":"ما مدى وضوح الرؤية التي يقدمها المدير للفريق وربطها بالأهداف؟","text_en":"ما مدى وضوح الرؤية التي يقدمها المدير للفريق وربطها بالأهداف؟"}]},{"title_ar":"ما مدى جودة قرارات المدير في المواقف الحرجة والمعقدة؟","questions":[{"id":"gm-2","type":"rating_1_5","text_ar":"ما مدى جودة قرارات المدير في المواقف الحرجة والمعقدة؟","text_en":"ما مدى جودة قرارات المدير في المواقف الحرجة والمعقدة؟"}]},{"title_ar":"ما مدى قدرة المدير على تحفيز الفريق وإدارة التغيير؟","questions":[{"id":"gm-3","type":"rating_1_5","text_ar":"ما مدى قدرة المدير على تحفيز الفريق وإدارة التغيير؟","text_en":"ما مدى قدرة المدير على تحفيز الفريق وإدارة التغيير؟"}]}]},{"title_ar":"إدارة الأداء","criteria":[{"title_ar":"ما مدى فعالية المدير في متابعة مؤشرات الأداء الرئيسية للقسم؟","questions":[{"id":"gm-4","type":"rating_1_5","text_ar":"ما مدى فعالية المدير في متابعة مؤشرات الأداء الرئيسية للقسم؟","text_en":"ما مدى فعالية المدير في متابعة مؤشرات الأداء الرئيسية للقسم؟"}]},{"title_ar":"ما مدى دعم المدير لتطوير الكفاءات القيادية داخل الفريق؟","questions":[{"id":"gm-5","type":"rating_1_5","text_ar":"ما مدى دعم المدير لتطوير الكفاءات القيادية داخل الفريق؟","text_en":"ما مدى دعم المدير لتطوير الكفاءات القيادية داخل الفريق؟"}]},{"title_ar":"ما مدى عدالة المدير في توزيع المهام وتقييم الأداء؟","questions":[{"id":"gm-6","type":"rating_1_5","text_ar":"ما مدى عدالة المدير في توزيع المهام وتقييم الأداء؟","text_en":"ما مدى عدالة المدير في توزيع المهام وتقييم الأداء؟"}]}]}],"questions":[{"id":"gm-1","type":"rating_1_5","text_ar":"ما مدى وضوح الرؤية التي يقدمها المدير للفريق وربطها بالأهداف؟","text_en":"ما مدى وضوح الرؤية التي يقدمها المدير للفريق وربطها بالأهداف؟"},{"id":"gm-2","type":"rating_1_5","text_ar":"ما مدى جودة قرارات المدير في المواقف الحرجة والمعقدة؟","text_en":"ما مدى جودة قرارات المدير في المواقف الحرجة والمعقدة؟"},{"id":"gm-3","type":"rating_1_5","text_ar":"ما مدى قدرة المدير على تحفيز الفريق وإدارة التغيير؟","text_en":"ما مدى قدرة المدير على تحفيز الفريق وإدارة التغيير؟"},{"id":"gm-4","type":"rating_1_5","text_ar":"ما مدى فعالية المدير في متابعة مؤشرات الأداء الرئيسية للقسم؟","text_en":"ما مدى فعالية المدير في متابعة مؤشرات الأداء الرئيسية للقسم؟"},{"id":"gm-5","type":"rating_1_5","text_ar":"ما مدى دعم المدير لتطوير الكفاءات القيادية داخل الفريق؟","text_en":"ما مدى دعم المدير لتطوير الكفاءات القيادية داخل الفريق؟"},{"id":"gm-6","type":"rating_1_5","text_ar":"ما مدى عدالة المدير في توزيع المهام وتقييم الأداء؟","text_en":"ما مدى عدالة المدير في توزيع المهام وتقييم الأداء؟"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم التنفيذيين ومدراء الأقسام'
);

update public.evaluation_templates
