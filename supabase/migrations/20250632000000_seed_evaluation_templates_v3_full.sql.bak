-- استبيان الشركة العام
insert into public.evaluation_templates (category, title, questions_jsonb)
select 'General', 'استبيان الشركة العام', '{"version":3,"title_en":"Company Survey","title_ar":"استبيان الشركة العام","categories":[{"title_ar":"بيئة العمل والموارد","criteria":[{"title_ar":"ما مدى رضاك عن بيئة العمل والمرافق المتاحة لأداء مهامك؟","questions":[{"id":"org-1","type":"rating_1_5","text_ar":"ما مدى رضاك عن بيئة العمل والمرافق المتاحة لأداء مهامك؟","text_en":"ما مدى رضاك عن بيئة العمل والمرافق المتاحة لأداء مهامك؟"}]},{"title_ar":"ما مدى توفر الأدوات والموارد اللازمة لإنجاز عملك بكفاءة؟","questions":[{"id":"org-2","type":"rating_1_5","text_ar":"ما مدى توفر الأدوات والموارد اللازمة لإنجاز عملك بكفاءة؟","text_en":"ما مدى توفر الأدوات والموارد اللازمة لإنجاز عملك بكفاءة؟"}]},{"title_ar":"ما مدى دعم المنشأة لتحقيق التوازن بين العمل والحياة؟","questions":[{"id":"org-3","type":"rating_1_5","text_ar":"ما مدى دعم المنشأة لتحقيق التوازن بين العمل والحياة؟","text_en":"ما مدى دعم المنشأة لتحقيق التوازن بين العمل والحياة؟"}]}]},{"title_ar":"القيادة والاستدامة","criteria":[{"title_ar":"ما مدى وضوح رؤية الإدارة وأولويات المنشأة لديك؟","questions":[{"id":"org-4","type":"rating_1_5","text_ar":"ما مدى وضوح رؤية الإدارة وأولويات المنشأة لديك؟","text_en":"ما مدى وضوح رؤية الإدارة وأولويات المنشأة لديك؟"}]},{"title_ar":"ما مدى ثقتك في قدرة المنشأة على تحقيق أهدافها الاستراتيجية؟","questions":[{"id":"org-5","type":"rating_1_5","text_ar":"ما مدى ثقتك في قدرة المنشأة على تحقيق أهدافها الاستراتيجية؟","text_en":"ما مدى ثقتك في قدرة المنشأة على تحقيق أهدافها الاستراتيجية؟"}]},{"title_ar":"ما مدى شعورك بالانتماء والفخر بالعمل في هذه المنشأة؟","questions":[{"id":"org-6","type":"rating_1_5","text_ar":"ما مدى شعورك بالانتماء والفخر بالعمل في هذه المنشأة؟","text_en":"ما مدى شعورك بالانتماء والفخر بالعمل في هذه المنشأة؟"}]}]}],"questions":[{"id":"org-1","type":"rating_1_5","text_ar":"ما مدى رضاك عن بيئة العمل والمرافق المتاحة لأداء مهامك؟","text_en":"ما مدى رضاك عن بيئة العمل والمرافق المتاحة لأداء مهامك؟"},{"id":"org-2","type":"rating_1_5","text_ar":"ما مدى توفر الأدوات والموارد اللازمة لإنجاز عملك بكفاءة؟","text_en":"ما مدى توفر الأدوات والموارد اللازمة لإنجاز عملك بكفاءة؟"},{"id":"org-3","type":"rating_1_5","text_ar":"ما مدى دعم المنشأة لتحقيق التوازن بين العمل والحياة؟","text_en":"ما مدى دعم المنشأة لتحقيق التوازن بين العمل والحياة؟"},{"id":"org-4","type":"rating_1_5","text_ar":"ما مدى وضوح رؤية الإدارة وأولويات المنشأة لديك؟","text_en":"ما مدى وضوح رؤية الإدارة وأولويات المنشأة لديك؟"},{"id":"org-5","type":"rating_1_5","text_ar":"ما مدى ثقتك في قدرة المنشأة على تحقيق أهدافها الاستراتيجية؟","text_en":"ما مدى ثقتك في قدرة المنشأة على تحقيق أهدافها الاستراتيجية؟"},{"id":"org-6","type":"rating_1_5","text_ar":"ما مدى شعورك بالانتماء والفخر بالعمل في هذه المنشأة؟","text_en":"ما مدى شعورك بالانتماء والفخر بالعمل في هذه المنشأة؟"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'استبيان الشركة العام'
);

