-- تقييم قوة العلامة التجارية وفعالية التسويق
insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Marketing', 'تقييم قوة العلامة التجارية وفعالية التسويق', '{"version":3,"title_en":"Brand Strength and Marketing Effectiveness Evaluation","title_ar":"تقييم قوة العلامة التجارية وفعالية التسويق","categories":[{"title_ar":"العلامة التجارية","criteria":[{"title_ar":"ما مدى انعكاس الهوية البصرية لقيم المنشأة الحقيقية؟","questions":[{"id":"mkt-1","type":"rating_1_5","text_ar":"ما مدى انعكاس الهوية البصرية لقيم المنشأة الحقيقية؟","text_en":"ما مدى انعكاس الهوية البصرية لقيم المنشأة الحقيقية؟"}]},{"title_ar":"ما مدى وضوح رسالة العلامة للعملاء والموظفين؟","questions":[{"id":"mkt-2","type":"rating_1_5","text_ar":"ما مدى وضوح رسالة العلامة للعملاء والموظفين؟","text_en":"ما مدى وضوح رسالة العلامة للعملاء والموظفين؟"}]},{"title_ar":"ما مدى قوة الانطباع الأول لدى العملاء عن العلامة؟","questions":[{"id":"mkt-3","type":"rating_1_5","text_ar":"ما مدى قوة الانطباع الأول لدى العملاء عن العلامة؟","text_en":"ما مدى قوة الانطباع الأول لدى العملاء عن العلامة؟"}]}]},{"title_ar":"فعالية التسويق","criteria":[{"title_ar":"ما مدى فعالية الحملات التسويقية في زيادة الوعي والتحويل؟","questions":[{"id":"mkt-4","type":"rating_1_5","text_ar":"ما مدى فعالية الحملات التسويقية في زيادة الوعي والتحويل؟","text_en":"ما مدى فعالية الحملات التسويقية في زيادة الوعي والتحويل؟"}]},{"title_ar":"ما مدى تفوق حملاتنا على المنافسين المباشرين في السوق؟","questions":[{"id":"mkt-5","type":"rating_1_5","text_ar":"ما مدى تفوق حملاتنا على المنافسين المباشرين في السوق؟","text_en":"ما مدى تفوق حملاتنا على المنافسين المباشرين في السوق؟"}]},{"title_ar":"ما مدى انتظام تزويد الفرق بمواد ترويجية محدثة؟","questions":[{"id":"mkt-6","type":"rating_1_5","text_ar":"ما مدى انتظام تزويد الفرق بمواد ترويجية محدثة؟","text_en":"ما مدى انتظام تزويد الفرق بمواد ترويجية محدثة؟"}]}]}],"questions":[{"id":"mkt-1","type":"rating_1_5","text_ar":"ما مدى انعكاس الهوية البصرية لقيم المنشأة الحقيقية؟","text_en":"ما مدى انعكاس الهوية البصرية لقيم المنشأة الحقيقية؟"},{"id":"mkt-2","type":"rating_1_5","text_ar":"ما مدى وضوح رسالة العلامة للعملاء والموظفين؟","text_en":"ما مدى وضوح رسالة العلامة للعملاء والموظفين؟"},{"id":"mkt-3","type":"rating_1_5","text_ar":"ما مدى قوة الانطباع الأول لدى العملاء عن العلامة؟","text_en":"ما مدى قوة الانطباع الأول لدى العملاء عن العلامة؟"},{"id":"mkt-4","type":"rating_1_5","text_ar":"ما مدى فعالية الحملات التسويقية في زيادة الوعي والتحويل؟","text_en":"ما مدى فعالية الحملات التسويقية في زيادة الوعي والتحويل؟"},{"id":"mkt-5","type":"rating_1_5","text_ar":"ما مدى تفوق حملاتنا على المنافسين المباشرين في السوق؟","text_en":"ما مدى تفوق حملاتنا على المنافسين المباشرين في السوق؟"},{"id":"mkt-6","type":"rating_1_5","text_ar":"ما مدى انتظام تزويد الفرق بمواد ترويجية محدثة؟","text_en":"ما مدى انتظام تزويد الفرق بمواد ترويجية محدثة؟"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم قوة العلامة التجارية وفعالية التسويق'
);

