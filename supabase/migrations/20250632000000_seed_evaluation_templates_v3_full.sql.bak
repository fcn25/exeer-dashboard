select 'Customer Service', 'تقييم تجربة العميل والتواصل', '{"version":3,"title_en":"Customer Experience and Communication Evaluation","title_ar":"تقييم تجربة العميل والتواصل","categories":[{"title_ar":"جودة تجربة العميل","criteria":[{"title_ar":"ما مدى سرعة استجابة الفريق لاستفسارات وشكاوى العملاء؟","questions":[{"id":"cx-1","type":"rating_1_5","text_ar":"ما مدى سرعة استجابة الفريق لاستفسارات وشكاوى العملاء؟","text_en":"ما مدى سرعة استجابة الفريق لاستفسارات وشكاوى العملاء؟"}]},{"title_ar":"ما مدى احترافية التعامل مع العملاء في المواقف الصعبة؟","questions":[{"id":"cx-2","type":"rating_1_5","text_ar":"ما مدى احترافية التعامل مع العملاء في المواقف الصعبة؟","text_en":"ما مدى احترافية التعامل مع العملاء في المواقف الصعبة؟"}]},{"title_ar":"ما مدى رضا العملاء عن جودة الحلول المقدمة؟","questions":[{"id":"cx-3","type":"rating_1_5","text_ar":"ما مدى رضا العملاء عن جودة الحلول المقدمة؟","text_en":"ما مدى رضا العملاء عن جودة الحلول المقدمة؟"}]}]},{"title_ar":"الأنظمة والتمكين","criteria":[{"title_ar":"ما مدى كفاية صلاحيات الموظفين لحل مشاكل العملاء دون تصعيد؟","questions":[{"id":"cx-4","type":"rating_1_5","text_ar":"ما مدى كفاية صلاحيات الموظفين لحل مشاكل العملاء دون تصعيد؟","text_en":"ما مدى كفاية صلاحيات الموظفين لحل مشاكل العملاء دون تصعيد؟"}]},{"title_ar":"ما مدى فعالية قنوات التواصل المتعددة (هاتف، واتساب، بريد)؟","questions":[{"id":"cx-5","type":"rating_1_5","text_ar":"ما مدى فعالية قنوات التواصل المتعددة (هاتف، واتساب، بريد)؟","text_en":"ما مدى فعالية قنوات التواصل المتعددة (هاتف، واتساب، بريد)؟"}]},{"title_ar":"ما مدى سهولة الوصول لمعلومات العميل عبر الأنظمة الحالية؟","questions":[{"id":"cx-6","type":"rating_1_5","text_ar":"ما مدى سهولة الوصول لمعلومات العميل عبر الأنظمة الحالية؟","text_en":"ما مدى سهولة الوصول لمعلومات العميل عبر الأنظمة الحالية؟"}]}]}],"questions":[{"id":"cx-1","type":"rating_1_5","text_ar":"ما مدى سرعة استجابة الفريق لاستفسارات وشكاوى العملاء؟","text_en":"ما مدى سرعة استجابة الفريق لاستفسارات وشكاوى العملاء؟"},{"id":"cx-2","type":"rating_1_5","text_ar":"ما مدى احترافية التعامل مع العملاء في المواقف الصعبة؟","text_en":"ما مدى احترافية التعامل مع العملاء في المواقف الصعبة؟"},{"id":"cx-3","type":"rating_1_5","text_ar":"ما مدى رضا العملاء عن جودة الحلول المقدمة؟","text_en":"ما مدى رضا العملاء عن جودة الحلول المقدمة؟"},{"id":"cx-4","type":"rating_1_5","text_ar":"ما مدى كفاية صلاحيات الموظفين لحل مشاكل العملاء دون تصعيد؟","text_en":"ما مدى كفاية صلاحيات الموظفين لحل مشاكل العملاء دون تصعيد؟"},{"id":"cx-5","type":"rating_1_5","text_ar":"ما مدى فعالية قنوات التواصل المتعددة (هاتف، واتساب، بريد)؟","text_en":"ما مدى فعالية قنوات التواصل المتعددة (هاتف، واتساب، بريد)؟"},{"id":"cx-6","type":"rating_1_5","text_ar":"ما مدى سهولة الوصول لمعلومات العميل عبر الأنظمة الحالية؟","text_en":"ما مدى سهولة الوصول لمعلومات العميل عبر الأنظمة الحالية؟"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم تجربة العميل والتواصل'
);

update public.evaluation_templates
set category = 'Customer Service',
    questions_jsonb = '{"version":3,"title_en":"Customer Experience and Communication Evaluation","title_ar":"تقييم تجربة العميل والتواصل","categories":[{"title_ar":"جودة تجربة العميل","criteria":[{"title_ar":"ما مدى سرعة استجابة الفريق لاستفسارات وشكاوى العملاء؟","questions":[{"id":"cx-1","type":"rating_1_5","text_ar":"ما مدى سرعة استجابة الفريق لاستفسارات وشكاوى العملاء؟","text_en":"ما مدى سرعة استجابة الفريق لاستفسارات وشكاوى العملاء؟"}]},{"title_ar":"ما مدى احترافية التعامل مع العملاء في المواقف الصعبة؟","questions":[{"id":"cx-2","type":"rating_1_5","text_ar":"ما مدى احترافية التعامل مع العملاء في المواقف الصعبة؟","text_en":"ما مدى احترافية التعامل مع العملاء في المواقف الصعبة؟"}]},{"title_ar":"ما مدى رضا العملاء عن جودة الحلول المقدمة؟","questions":[{"id":"cx-3","type":"rating_1_5","text_ar":"ما مدى رضا العملاء عن جودة الحلول المقدمة؟","text_en":"ما مدى رضا العملاء عن جودة الحلول المقدمة؟"}]}]},{"title_ar":"الأنظمة والتمكين","criteria":[{"title_ar":"ما مدى كفاية صلاحيات الموظفين لحل مشاكل العملاء دون تصعيد؟","questions":[{"id":"cx-4","type":"rating_1_5","text_ar":"ما مدى كفاية صلاحيات الموظفين لحل مشاكل العملاء دون تصعيد؟","text_en":"ما مدى كفاية صلاحيات الموظفين لحل مشاكل العملاء دون تصعيد؟"}]},{"title_ar":"ما مدى فعالية قنوات التواصل المتعددة (هاتف، واتساب، بريد)؟","questions":[{"id":"cx-5","type":"rating_1_5","text_ar":"ما مدى فعالية قنوات التواصل المتعددة (هاتف، واتساب، بريد)؟","text_en":"ما مدى فعالية قنوات التواصل المتعددة (هاتف، واتساب، بريد)؟"}]},{"title_ar":"ما مدى سهولة الوصول لمعلومات العميل عبر الأنظمة الحالية؟","questions":[{"id":"cx-6","type":"rating_1_5","text_ar":"ما مدى سهولة الوصول لمعلومات العميل عبر الأنظمة الحالية؟","text_en":"ما مدى سهولة الوصول لمعلومات العميل عبر الأنظمة الحالية؟"}]}]}],"questions":[{"id":"cx-1","type":"rating_1_5","text_ar":"ما مدى سرعة استجابة الفريق لاستفسارات وشكاوى العملاء؟","text_en":"ما مدى سرعة استجابة الفريق لاستفسارات وشكاوى العملاء؟"},{"id":"cx-2","type":"rating_1_5","text_ar":"ما مدى احترافية التعامل مع العملاء في المواقف الصعبة؟","text_en":"ما مدى احترافية التعامل مع العملاء في المواقف الصعبة؟"},{"id":"cx-3","type":"rating_1_5","text_ar":"ما مدى رضا العملاء عن جودة الحلول المقدمة؟","text_en":"ما مدى رضا العملاء عن جودة الحلول المقدمة؟"},{"id":"cx-4","type":"rating_1_5","text_ar":"ما مدى كفاية صلاحيات الموظفين لحل مشاكل العملاء دون تصعيد؟","text_en":"ما مدى كفاية صلاحيات الموظفين لحل مشاكل العملاء دون تصعيد؟"},{"id":"cx-5","type":"rating_1_5","text_ar":"ما مدى فعالية قنوات التواصل المتعددة (هاتف، واتساب، بريد)؟","text_en":"ما مدى فعالية قنوات التواصل المتعددة (هاتف، واتساب، بريد)؟"},{"id":"cx-6","type":"rating_1_5","text_ar":"ما مدى سهولة الوصول لمعلومات العميل عبر الأنظمة الحالية؟","text_en":"ما مدى سهولة الوصول لمعلومات العميل عبر الأنظمة الحالية؟"}]}'::jsonb
where title = 'تقييم تجربة العميل والتواصل';


-- تقييم كفاءة سلسلة الإمداد والمخزون
insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Supply Chain', 'تقييم كفاءة سلسلة الإمداد والمخزون', '{"version":3,"title_en":"Supply Chain and Inventory Efficiency Evaluation","title_ar":"تقييم كفاءة سلسلة الإمداد والمخزون","categories":[{"title_ar":"إدارة المخزون","criteria":[{"title_ar":"ما مدى تطابق الجرد الفعلي مع بيانات النظام؟","questions":[{"id":"sc-1","type":"rating_1_5","text_ar":"ما مدى تطابق الجرد الفعلي مع بيانات النظام؟","text_en":"ما مدى تطابق الجرد الفعلي مع بيانات النظام؟"}]},{"title_ar":"ما مدى دقة التنبؤ بالطلب وخطط إعادة التوريد؟","questions":[{"id":"sc-2","type":"rating_1_5","text_ar":"ما مدى دقة التنبؤ بالطلب وخطط إعادة التوريد؟","text_en":"ما مدى دقة التنبؤ بالطلب وخطط إعادة التوريد؟"}]},{"title_ar":"ما مدى فعالية إجراءات التعامل مع المواد التالفة أو المتقادمة؟","questions":[{"id":"sc-3","type":"rating_1_5","text_ar":"ما مدى فعالية إجراءات التعامل مع المواد التالفة أو المتقادمة؟","text_en":"ما مدى فعالية إجراءات التعامل مع المواد التالفة أو المتقادمة؟"}]}]},{"title_ar":"العمليات اللوجستية","criteria":[{"title_ar":"ما مدى سرعة وكفاءة عمليات الاستلام والتسليم في المستودع؟","questions":[{"id":"sc-4","type":"rating_1_5","text_ar":"ما مدى سرعة وكفاءة عمليات الاستلام والتسليم في المستودع؟","text_en":"ما مدى سرعة وكفاءة عمليات الاستلام والتسليم في المستودع؟"}]},{"title_ar":"ما مدى الالتزام بمعايير السلامة والتخزين في المستودعات؟","questions":[{"id":"sc-5","type":"rating_1_5","text_ar":"ما مدى الالتزام بمعايير السلامة والتخزين في المستودعات؟","text_en":"ما مدى الالتزام بمعايير السلامة والتخزين في المستودعات؟"}]},{"title_ar":"ما مدى صرامة ضوابط الدخول والخروج لمنع الفقد أو التلاعب؟","questions":[{"id":"sc-6","type":"rating_1_5","text_ar":"ما مدى صرامة ضوابط الدخول والخروج لمنع الفقد أو التلاعب؟","text_en":"ما مدى صرامة ضوابط الدخول والخروج لمنع الفقد أو التلاعب؟"}]}]}],"questions":[{"id":"sc-1","type":"rating_1_5","text_ar":"ما مدى تطابق الجرد الفعلي مع بيانات النظام؟","text_en":"ما مدى تطابق الجرد الفعلي مع بيانات النظام؟"},{"id":"sc-2","type":"rating_1_5","text_ar":"ما مدى دقة التنبؤ بالطلب وخطط إعادة التوريد؟","text_en":"ما مدى دقة التنبؤ بالطلب وخطط إعادة التوريد؟"},{"id":"sc-3","type":"rating_1_5","text_ar":"ما مدى فعالية إجراءات التعامل مع المواد التالفة أو المتقادمة؟","text_en":"ما مدى فعالية إجراءات التعامل مع المواد التالفة أو المتقادمة؟"},{"id":"sc-4","type":"rating_1_5","text_ar":"ما مدى سرعة وكفاءة عمليات الاستلام والتسليم في المستودع؟","text_en":"ما مدى سرعة وكفاءة عمليات الاستلام والتسليم في المستودع؟"},{"id":"sc-5","type":"rating_1_5","text_ar":"ما مدى الالتزام بمعايير السلامة والتخزين في المستودعات؟","text_en":"ما مدى الالتزام بمعايير السلامة والتخزين في المستودعات؟"},{"id":"sc-6","type":"rating_1_5","text_ar":"ما مدى صرامة ضوابط الدخول والخروج لمنع الفقد أو التلاعب؟","text_en":"ما مدى صرامة ضوابط الدخول والخروج لمنع الفقد أو التلاعب؟"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم كفاءة سلسلة الإمداد والمخزون'
);

