-- تقييم الجاهزية الرقمية والذكاء الاصطناعي
insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Technology', 'تقييم الجاهزية الرقمية والذكاء الاصطناعي', '{"version":3,"title_en":"Digital Readiness and AI Assessment","title_ar":"تقييم الجاهزية الرقمية والذكاء الاصطناعي","categories":[{"title_ar":"الجاهزية الرقمية","criteria":[{"title_ar":"ما مدى نضج الأنظمة الرقمية الأساسية في دعم عملك اليومي؟","questions":[{"id":"dig-1","type":"rating_1_5","text_ar":"ما مدى نضج الأنظمة الرقمية الأساسية في دعم عملك اليومي؟","text_en":"ما مدى نضج الأنظمة الرقمية الأساسية في دعم عملك اليومي؟"}]},{"title_ar":"ما مدى فعالية حماية البيانات وأمن المعلومات في منشأتك؟","questions":[{"id":"dig-2","type":"rating_1_5","text_ar":"ما مدى فعالية حماية البيانات وأمن المعلومات في منشأتك؟","text_en":"ما مدى فعالية حماية البيانات وأمن المعلومات في منشأتك؟"}]},{"title_ar":"ما مدى سهولة الوصول للبيانات والتقارير اللازمة لاتخاذ القرار؟","questions":[{"id":"dig-3","type":"rating_1_5","text_ar":"ما مدى سهولة الوصول للبيانات والتقارير اللازمة لاتخاذ القرار؟","text_en":"ما مدى سهولة الوصول للبيانات والتقارير اللازمة لاتخاذ القرار؟"}]}]},{"title_ar":"الذكاء الاصطناعي","criteria":[{"title_ar":"ما مدى وعيك بأدوات الذكاء الاصطناعي المفيدة لمهامك؟","questions":[{"id":"dig-4","type":"rating_1_5","text_ar":"ما مدى وعيك بأدوات الذكاء الاصطناعي المفيدة لمهامك؟","text_en":"ما مدى وعيك بأدوات الذكاء الاصطناعي المفيدة لمهامك؟"}]},{"title_ar":"ما مدى استعدادك لتبني حلول ذكية لأتمتة المهام المتكررة؟","questions":[{"id":"dig-5","type":"rating_1_5","text_ar":"ما مدى استعدادك لتبني حلول ذكية لأتمتة المهام المتكررة؟","text_en":"ما مدى استعدادك لتبني حلول ذكية لأتمتة المهام المتكررة؟"}]},{"title_ar":"ما مدى جودة التدريب المقدم على المهارات الرقمية والذكاء الاصطناعي؟","questions":[{"id":"dig-6","type":"rating_1_5","text_ar":"ما مدى جودة التدريب المقدم على المهارات الرقمية والذكاء الاصطناعي؟","text_en":"ما مدى جودة التدريب المقدم على المهارات الرقمية والذكاء الاصطناعي؟"}]}]}],"questions":[{"id":"dig-1","type":"rating_1_5","text_ar":"ما مدى نضج الأنظمة الرقمية الأساسية في دعم عملك اليومي؟","text_en":"ما مدى نضج الأنظمة الرقمية الأساسية في دعم عملك اليومي؟"},{"id":"dig-2","type":"rating_1_5","text_ar":"ما مدى فعالية حماية البيانات وأمن المعلومات في منشأتك؟","text_en":"ما مدى فعالية حماية البيانات وأمن المعلومات في منشأتك؟"},{"id":"dig-3","type":"rating_1_5","text_ar":"ما مدى سهولة الوصول للبيانات والتقارير اللازمة لاتخاذ القرار؟","text_en":"ما مدى سهولة الوصول للبيانات والتقارير اللازمة لاتخاذ القرار؟"},{"id":"dig-4","type":"rating_1_5","text_ar":"ما مدى وعيك بأدوات الذكاء الاصطناعي المفيدة لمهامك؟","text_en":"ما مدى وعيك بأدوات الذكاء الاصطناعي المفيدة لمهامك؟"},{"id":"dig-5","type":"rating_1_5","text_ar":"ما مدى استعدادك لتبني حلول ذكية لأتمتة المهام المتكررة؟","text_en":"ما مدى استعدادك لتبني حلول ذكية لأتمتة المهام المتكررة؟"},{"id":"dig-6","type":"rating_1_5","text_ar":"ما مدى جودة التدريب المقدم على المهارات الرقمية والذكاء الاصطناعي؟","text_en":"ما مدى جودة التدريب المقدم على المهارات الرقمية والذكاء الاصطناعي؟"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم الجاهزية الرقمية والذكاء الاصطناعي'
);

