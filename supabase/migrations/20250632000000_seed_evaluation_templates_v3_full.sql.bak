-- التقييم الذاتي للموظف
insert into public.evaluation_templates (category, title, questions_jsonb)
select 'General', 'التقييم الذاتي للموظف', '{"version":3,"title_en":"Employee Self Evaluation","title_ar":"التقييم الذاتي للموظف","categories":[{"title_ar":"الأداء والإنجاز","criteria":[{"title_ar":"ما مدى التزامي بالأهداف المحددة لي خلال فترة التقييم؟","questions":[{"id":"self-1","type":"rating_1_5","text_ar":"ما مدى التزامي بالأهداف المحددة لي خلال فترة التقييم؟","text_en":"ما مدى التزامي بالأهداف المحددة لي خلال فترة التقييم؟"}]},{"title_ar":"ما مدى جودة مخرجاتي والالتزام بالمعايير المتفق عليها؟","questions":[{"id":"self-2","type":"rating_1_5","text_ar":"ما مدى جودة مخرجاتي والالتزام بالمعايير المتفق عليها؟","text_en":"ما مدى جودة مخرجاتي والالتزام بالمعايير المتفق عليها؟"}]},{"title_ar":"ما أبرز إنجازاتي التي أسهمت في نجاح الفريق؟","questions":[{"id":"self-3","type":"text","text_ar":"ما أبرز إنجازاتي التي أسهمت في نجاح الفريق؟","text_en":"ما أبرز إنجازاتي التي أسهمت في نجاح الفريق؟"}]}]},{"title_ar":"التطوير والتحسين","criteria":[{"title_ar":"ما التحديات الرئيسية التي واجهتها وكيف تعاملت معها؟","questions":[{"id":"self-4","type":"text","text_ar":"ما التحديات الرئيسية التي واجهتها وكيف تعاملت معها؟","text_en":"ما التحديات الرئيسية التي واجهتها وكيف تعاملت معها؟"}]},{"title_ar":"ما المهارات التي طورتها خلال الفترة الماضية؟","questions":[{"id":"self-5","type":"text","text_ar":"ما المهارات التي طورتها خلال الفترة الماضية؟","text_en":"ما المهارات التي طورتها خلال الفترة الماضية؟"}]},{"title_ar":"ما مجالات التحسين التي أركز عليها في الفترة القادمة؟","questions":[{"id":"self-6","type":"text","text_ar":"ما مجالات التحسين التي أركز عليها في الفترة القادمة؟","text_en":"ما مجالات التحسين التي أركز عليها في الفترة القادمة؟"}]}]}],"questions":[{"id":"self-1","type":"rating_1_5","text_ar":"ما مدى التزامي بالأهداف المحددة لي خلال فترة التقييم؟","text_en":"ما مدى التزامي بالأهداف المحددة لي خلال فترة التقييم؟"},{"id":"self-2","type":"rating_1_5","text_ar":"ما مدى جودة مخرجاتي والالتزام بالمعايير المتفق عليها؟","text_en":"ما مدى جودة مخرجاتي والالتزام بالمعايير المتفق عليها؟"},{"id":"self-3","type":"text","text_ar":"ما أبرز إنجازاتي التي أسهمت في نجاح الفريق؟","text_en":"ما أبرز إنجازاتي التي أسهمت في نجاح الفريق؟"},{"id":"self-4","type":"text","text_ar":"ما التحديات الرئيسية التي واجهتها وكيف تعاملت معها؟","text_en":"ما التحديات الرئيسية التي واجهتها وكيف تعاملت معها؟"},{"id":"self-5","type":"text","text_ar":"ما المهارات التي طورتها خلال الفترة الماضية؟","text_en":"ما المهارات التي طورتها خلال الفترة الماضية؟"},{"id":"self-6","type":"text","text_ar":"ما مجالات التحسين التي أركز عليها في الفترة القادمة؟","text_en":"ما مجالات التحسين التي أركز عليها في الفترة القادمة؟"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'التقييم الذاتي للموظف'
);

