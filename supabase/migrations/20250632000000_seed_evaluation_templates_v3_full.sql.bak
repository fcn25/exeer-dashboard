-- تقييم كفاءة الإنتاج والجودة
insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Production', 'تقييم كفاءة الإنتاج والجودة', '{"version":3,"title_en":"Production Efficiency and Quality Evaluation","title_ar":"تقييم كفاءة الإنتاج والجودة","categories":[{"title_ar":"كفاءة الإنتاج","criteria":[{"title_ar":"ما مدى استمرارية تشغيل خطوط الإنتاج دون توقفات غير مخططة؟","questions":[{"id":"prod-1","type":"rating_0_100","text_ar":"ما مدى استمرارية تشغيل خطوط الإنتاج دون توقفات غير مخططة؟","text_en":"ما مدى استمرارية تشغيل خطوط الإنتاج دون توقفات غير مخططة؟"}]},{"title_ar":"ما مدى كفاءة فريق الصيانة في معالجة الأعطال الطارئة؟","questions":[{"id":"prod-2","type":"rating_1_5","text_ar":"ما مدى كفاءة فريق الصيانة في معالجة الأعطال الطارئة؟","text_en":"ما مدى كفاءة فريق الصيانة في معالجة الأعطال الطارئة؟"}]},{"title_ar":"ما مدى فعالية تخطيط الطاقة الإنتاجية لمواجهة ذروة الطلب؟","questions":[{"id":"prod-3","type":"rating_1_5","text_ar":"ما مدى فعالية تخطيط الطاقة الإنتاجية لمواجهة ذروة الطلب؟","text_en":"ما مدى فعالية تخطيط الطاقة الإنتاجية لمواجهة ذروة الطلب؟"}]}]},{"title_ar":"الجودة والسلامة","criteria":[{"title_ar":"ما مدى التزام العمال بمعدات الوقاية الشخصية في منطقة الإنتاج؟","questions":[{"id":"prod-4","type":"rating_1_5","text_ar":"ما مدى التزام العمال بمعدات الوقاية الشخصية في منطقة الإنتاج؟","text_en":"ما مدى التزام العمال بمعدات الوقاية الشخصية في منطقة الإنتاج؟"}]},{"title_ar":"ما مدى سرعة الاستجابة عند اكتشاف عيب أثناء التصنيع؟","questions":[{"id":"prod-5","type":"rating_1_5","text_ar":"ما مدى سرعة الاستجابة عند اكتشاف عيب أثناء التصنيع؟","text_en":"ما مدى سرعة الاستجابة عند اكتشاف عيب أثناء التصنيع؟"}]},{"title_ar":"ما مدى ملاءمة بيئة الإنتاج (إضاءة، تهوية، تخطيط) للسلامة والتركيز؟","questions":[{"id":"prod-6","type":"rating_1_5","text_ar":"ما مدى ملاءمة بيئة الإنتاج (إضاءة، تهوية، تخطيط) للسلامة والتركيز؟","text_en":"ما مدى ملاءمة بيئة الإنتاج (إضاءة، تهوية، تخطيط) للسلامة والتركيز؟"}]}]}],"questions":[{"id":"prod-1","type":"rating_0_100","text_ar":"ما مدى استمرارية تشغيل خطوط الإنتاج دون توقفات غير مخططة؟","text_en":"ما مدى استمرارية تشغيل خطوط الإنتاج دون توقفات غير مخططة؟"},{"id":"prod-2","type":"rating_1_5","text_ar":"ما مدى كفاءة فريق الصيانة في معالجة الأعطال الطارئة؟","text_en":"ما مدى كفاءة فريق الصيانة في معالجة الأعطال الطارئة؟"},{"id":"prod-3","type":"rating_1_5","text_ar":"ما مدى فعالية تخطيط الطاقة الإنتاجية لمواجهة ذروة الطلب؟","text_en":"ما مدى فعالية تخطيط الطاقة الإنتاجية لمواجهة ذروة الطلب؟"},{"id":"prod-4","type":"rating_1_5","text_ar":"ما مدى التزام العمال بمعدات الوقاية الشخصية في منطقة الإنتاج؟","text_en":"ما مدى التزام العمال بمعدات الوقاية الشخصية في منطقة الإنتاج؟"},{"id":"prod-5","type":"rating_1_5","text_ar":"ما مدى سرعة الاستجابة عند اكتشاف عيب أثناء التصنيع؟","text_en":"ما مدى سرعة الاستجابة عند اكتشاف عيب أثناء التصنيع؟"},{"id":"prod-6","type":"rating_1_5","text_ar":"ما مدى ملاءمة بيئة الإنتاج (إضاءة، تهوية، تخطيط) للسلامة والتركيز؟","text_en":"ما مدى ملاءمة بيئة الإنتاج (إضاءة، تهوية، تخطيط) للسلامة والتركيز؟"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم كفاءة الإنتاج والجودة'
);

