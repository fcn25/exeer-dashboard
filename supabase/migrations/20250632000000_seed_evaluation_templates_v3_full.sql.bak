-- تقييم الكفاءة المالية والامتثال
insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Finance', 'تقييم الكفاءة المالية والامتثال', '{"version":3,"title_en":"Financial Efficiency and Compliance Evaluation","title_ar":"تقييم الكفاءة المالية والامتثال","categories":[{"title_ar":"الكفاءة المالية","criteria":[{"title_ar":"ما مدى سرعة معالجة الطلبات والعمليات المالية لقسمك؟","questions":[{"id":"fin-1","type":"rating_1_5","text_ar":"ما مدى سرعة معالجة الطلبات والعمليات المالية لقسمك؟","text_en":"ما مدى سرعة معالجة الطلبات والعمليات المالية لقسمك؟"}]},{"title_ar":"ما مدى وضوح النماذج والمتطلبات المالية المطلوبة منك؟","questions":[{"id":"fin-2","type":"rating_1_5","text_ar":"ما مدى وضوح النماذج والمتطلبات المالية المطلوبة منك؟","text_en":"ما مدى وضوح النماذج والمتطلبات المالية المطلوبة منك؟"}]},{"title_ar":"ما مدى دقة البيانات المالية المشتركة داخل قسمك؟","questions":[{"id":"fin-3","type":"rating_1_5","text_ar":"ما مدى دقة البيانات المالية المشتركة داخل قسمك؟","text_en":"ما مدى دقة البيانات المالية المشتركة داخل قسمك؟"}]}]},{"title_ar":"الامتثال والرقابة","criteria":[{"title_ar":"ما مدى فائدة التقارير الدورية للميزانية مقابل المنفذ؟","questions":[{"id":"fin-4","type":"rating_1_5","text_ar":"ما مدى فائدة التقارير الدورية للميزانية مقابل المنفذ؟","text_en":"ما مدى فائدة التقارير الدورية للميزانية مقابل المنفذ؟"}]},{"title_ar":"ما مدى فعالية السياسات المالية في الحد من الهدر؟","questions":[{"id":"fin-5","type":"rating_1_5","text_ar":"ما مدى فعالية السياسات المالية في الحد من الهدر؟","text_en":"ما مدى فعالية السياسات المالية في الحد من الهدر؟"}]},{"title_ar":"ما مدى التزام قسمك بمتطلبات المراجعة والتدقيق الداخلي؟","questions":[{"id":"fin-6","type":"rating_1_5","text_ar":"ما مدى التزام قسمك بمتطلبات المراجعة والتدقيق الداخلي؟","text_en":"ما مدى التزام قسمك بمتطلبات المراجعة والتدقيق الداخلي؟"}]}]}],"questions":[{"id":"fin-1","type":"rating_1_5","text_ar":"ما مدى سرعة معالجة الطلبات والعمليات المالية لقسمك؟","text_en":"ما مدى سرعة معالجة الطلبات والعمليات المالية لقسمك؟"},{"id":"fin-2","type":"rating_1_5","text_ar":"ما مدى وضوح النماذج والمتطلبات المالية المطلوبة منك؟","text_en":"ما مدى وضوح النماذج والمتطلبات المالية المطلوبة منك؟"},{"id":"fin-3","type":"rating_1_5","text_ar":"ما مدى دقة البيانات المالية المشتركة داخل قسمك؟","text_en":"ما مدى دقة البيانات المالية المشتركة داخل قسمك؟"},{"id":"fin-4","type":"rating_1_5","text_ar":"ما مدى فائدة التقارير الدورية للميزانية مقابل المنفذ؟","text_en":"ما مدى فائدة التقارير الدورية للميزانية مقابل المنفذ؟"},{"id":"fin-5","type":"rating_1_5","text_ar":"ما مدى فعالية السياسات المالية في الحد من الهدر؟","text_en":"ما مدى فعالية السياسات المالية في الحد من الهدر؟"},{"id":"fin-6","type":"rating_1_5","text_ar":"ما مدى التزام قسمك بمتطلبات المراجعة والتدقيق الداخلي؟","text_en":"ما مدى التزام قسمك بمتطلبات المراجعة والتدقيق الداخلي؟"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم الكفاءة المالية والامتثال'
);

