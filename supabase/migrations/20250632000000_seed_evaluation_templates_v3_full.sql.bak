insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Procurement', 'تقييم كفاءة المشتريات وسلاسل الإمداد', '{"version":3,"title_en":"Procurement and Supply Chain Efficiency Evaluation","title_ar":"تقييم كفاءة المشتريات وسلاسل الإمداد","categories":[{"title_ar":"كفاءة المشتريات","criteria":[{"title_ar":"ما مدى سرعة تلبية طلبات الشراء بعد اعتمادها؟","questions":[{"id":"proc-1","type":"rating_0_100","text_ar":"ما مدى سرعة تلبية طلبات الشراء بعد اعتمادها؟","text_en":"ما مدى سرعة تلبية طلبات الشراء بعد اعتمادها؟"}]},{"title_ar":"ما مدى مطابقة المواد الموردة لمواصفات أمر الشراء؟","questions":[{"id":"proc-2","type":"rating_1_5","text_ar":"ما مدى مطابقة المواد الموردة لمواصفات أمر الشراء؟","text_en":"ما مدى مطابقة المواد الموردة لمواصفات أمر الشراء؟"}]},{"title_ar":"ما مدى فعالية إدارة الموردين وتقليل التأخير التشغيلي؟","questions":[{"id":"proc-3","type":"rating_1_5","text_ar":"ما مدى فعالية إدارة الموردين وتقليل التأخير التشغيلي؟","text_en":"ما مدى فعالية إدارة الموردين وتقليل التأخير التشغيلي؟"}]}]},{"title_ar":"العقود والامتثال","criteria":[{"title_ar":"ما مدى كفاية العقود في حماية حقوق المنشأة؟","questions":[{"id":"proc-4","type":"rating_1_5","text_ar":"ما مدى كفاية العقود في حماية حقوق المنشأة؟","text_en":"ما مدى كفاية العقود في حماية حقوق المنشأة؟"}]},{"title_ar":"ما مدى وضوح إجراءات اعتماد موردين جدد؟","questions":[{"id":"proc-5","type":"rating_1_5","text_ar":"ما مدى وضوح إجراءات اعتماد موردين جدد؟","text_en":"ما مدى وضوح إجراءات اعتماد موردين جدد؟"}]},{"title_ar":"ما مدى الالتزام بإشعارات تجديد أو انتهاء العقود ذات الصلة؟","questions":[{"id":"proc-6","type":"rating_1_5","text_ar":"ما مدى الالتزام بإشعارات تجديد أو انتهاء العقود ذات الصلة؟","text_en":"ما مدى الالتزام بإشعارات تجديد أو انتهاء العقود ذات الصلة؟"}]}]}],"questions":[{"id":"proc-1","type":"rating_0_100","text_ar":"ما مدى سرعة تلبية طلبات الشراء بعد اعتمادها؟","text_en":"ما مدى سرعة تلبية طلبات الشراء بعد اعتمادها؟"},{"id":"proc-2","type":"rating_1_5","text_ar":"ما مدى مطابقة المواد الموردة لمواصفات أمر الشراء؟","text_en":"ما مدى مطابقة المواد الموردة لمواصفات أمر الشراء؟"},{"id":"proc-3","type":"rating_1_5","text_ar":"ما مدى فعالية إدارة الموردين وتقليل التأخير التشغيلي؟","text_en":"ما مدى فعالية إدارة الموردين وتقليل التأخير التشغيلي؟"},{"id":"proc-4","type":"rating_1_5","text_ar":"ما مدى كفاية العقود في حماية حقوق المنشأة؟","text_en":"ما مدى كفاية العقود في حماية حقوق المنشأة؟"},{"id":"proc-5","type":"rating_1_5","text_ar":"ما مدى وضوح إجراءات اعتماد موردين جدد؟","text_en":"ما مدى وضوح إجراءات اعتماد موردين جدد؟"},{"id":"proc-6","type":"rating_1_5","text_ar":"ما مدى الالتزام بإشعارات تجديد أو انتهاء العقود ذات الصلة؟","text_en":"ما مدى الالتزام بإشعارات تجديد أو انتهاء العقود ذات الصلة؟"}]}'::jsonb
