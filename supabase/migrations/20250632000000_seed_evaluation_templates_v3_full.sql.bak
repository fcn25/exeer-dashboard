insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Culture', 'استبيان ثقافة الابتكار والارتباط الوظيفي', '{"version":3,"title_en":"Innovation Culture and Employee Engagement Survey","title_ar":"استبيان ثقافة الابتكار والارتباط الوظيفي","categories":[{"title_ar":"الابتكار","criteria":[{"title_ar":"ما مدى تشجيع المنشأة على اقتراح أفكار تطويرية جديدة؟","questions":[{"id":"inn-1","type":"rating_1_5","text_ar":"ما مدى تشجيع المنشأة على اقتراح أفكار تطويرية جديدة؟","text_en":"ما مدى تشجيع المنشأة على اقتراح أفكار تطويرية جديدة؟"}]},{"title_ar":"ما مدى سرعة تنفيذ المبادرات التحسينية المعتمدة؟","questions":[{"id":"inn-2","type":"rating_1_5","text_ar":"ما مدى سرعة تنفيذ المبادرات التحسينية المعتمدة؟","text_en":"ما مدى سرعة تنفيذ المبادرات التحسينية المعتمدة؟"}]},{"title_ar":"ما مدى توفر الأدوات والتقنيات الداعمة للابتكار في عملك؟","questions":[{"id":"inn-3","type":"rating_1_5","text_ar":"ما مدى توفر الأدوات والتقنيات الداعمة للابتكار في عملك؟","text_en":"ما مدى توفر الأدوات والتقنيات الداعمة للابتكار في عملك؟"}]}]},{"title_ar":"الارتباط الوظيفي","criteria":[{"title_ar":"ما مدى شعورك بالتقدير عند تقديم جهد استثنائي؟","questions":[{"id":"inn-4","type":"rating_1_5","text_ar":"ما مدى شعورك بالتقدير عند تقديم جهد استثنائي؟","text_en":"ما مدى شعورك بالتقدير عند تقديم جهد استثنائي؟"}]},{"title_ar":"ما مدى مشاركتك في أهداف الفريق والمنشأة؟","questions":[{"id":"inn-5","type":"rating_1_5","text_ar":"ما مدى مشاركتك في أهداف الفريق والمنشأة؟","text_en":"ما مدى مشاركتك في أهداف الفريق والمنشأة؟"}]},{"title_ar":"ما مدى رغبتك في الاستمرار في المنشأة خلال السنوات القادمة؟","questions":[{"id":"inn-6","type":"rating_1_5","text_ar":"ما مدى رغبتك في الاستمرار في المنشأة خلال السنوات القادمة؟","text_en":"ما مدى رغبتك في الاستمرار في المنشأة خلال السنوات القادمة؟"}]}]}],"questions":[{"id":"inn-1","type":"rating_1_5","text_ar":"ما مدى تشجيع المنشأة على اقتراح أفكار تطويرية جديدة؟","text_en":"ما مدى تشجيع المنشأة على اقتراح أفكار تطويرية جديدة؟"},{"id":"inn-2","type":"rating_1_5","text_ar":"ما مدى سرعة تنفيذ المبادرات التحسينية المعتمدة؟","text_en":"ما مدى سرعة تنفيذ المبادرات التحسينية المعتمدة؟"},{"id":"inn-3","type":"rating_1_5","text_ar":"ما مدى توفر الأدوات والتقنيات الداعمة للابتكار في عملك؟","text_en":"ما مدى توفر الأدوات والتقنيات الداعمة للابتكار في عملك؟"},{"id":"inn-4","type":"rating_1_5","text_ar":"ما مدى شعورك بالتقدير عند تقديم جهد استثنائي؟","text_en":"ما مدى شعورك بالتقدير عند تقديم جهد استثنائي؟"},{"id":"inn-5","type":"rating_1_5","text_ar":"ما مدى مشاركتك في أهداف الفريق والمنشأة؟","text_en":"ما مدى مشاركتك في أهداف الفريق والمنشأة؟"},{"id":"inn-6","type":"rating_1_5","text_ar":"ما مدى رغبتك في الاستمرار في المنشأة خلال السنوات القادمة؟","text_en":"ما مدى رغبتك في الاستمرار في المنشأة خلال السنوات القادمة؟"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'استبيان ثقافة الابتكار والارتباط الوظيفي'
);

