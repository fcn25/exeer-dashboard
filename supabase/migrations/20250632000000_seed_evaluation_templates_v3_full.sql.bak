-- نموذج تقييم المدير للموظف
insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Management', 'نموذج تقييم المدير للموظف', '{"version":3,"title_en":"Manager to Employee Form","title_ar":"نموذج تقييم المدير للموظف","categories":[{"title_ar":"جودة الأداء","criteria":[{"title_ar":"ما مدى تحقيق الموظف للأهداف والمؤشرات المحددة للفترة؟","questions":[{"id":"me-1","type":"rating_1_5","text_ar":"ما مدى تحقيق الموظف للأهداف والمؤشرات المحددة للفترة؟","text_en":"ما مدى تحقيق الموظف للأهداف والمؤشرات المحددة للفترة؟"}]},{"title_ar":"ما مدى جودة مخرجات العمل والالتزام بالمواعيد النهائية؟","questions":[{"id":"me-2","type":"rating_1_5","text_ar":"ما مدى جودة مخرجات العمل والالتزام بالمواعيد النهائية؟","text_en":"ما مدى جودة مخرجات العمل والالتزام بالمواعيد النهائية؟"}]},{"title_ar":"ما مدى قدرة الموظف على العمل تحت الضغط مع الحفاظ على الجودة؟","questions":[{"id":"me-3","type":"rating_1_5","text_ar":"ما مدى قدرة الموظف على العمل تحت الضغط مع الحفاظ على الجودة؟","text_en":"ما مدى قدرة الموظف على العمل تحت الضغط مع الحفاظ على الجودة؟"}]}]},{"title_ar":"السلوكيات والتطوير","criteria":[{"title_ar":"ما مدى فعالية الموظف في التعاون والتواصل مع الزملاء والإدارات؟","questions":[{"id":"me-4","type":"rating_1_5","text_ar":"ما مدى فعالية الموظف في التعاون والتواصل مع الزملاء والإدارات؟","text_en":"ما مدى فعالية الموظف في التعاون والتواصل مع الزملاء والإدارات؟"}]},{"title_ar":"ما مدى استجابة الموظف للتغذية الراجعة وخطط التطوير؟","questions":[{"id":"me-5","type":"rating_1_5","text_ar":"ما مدى استجابة الموظف للتغذية الراجعة وخطط التطوير؟","text_en":"ما مدى استجابة الموظف للتغذية الراجعة وخطط التطوير؟"}]},{"title_ar":"ما مدى جاهزية الموظف لتحمل مسؤوليات أكبر في المستقبل القريب؟","questions":[{"id":"me-6","type":"rating_1_5","text_ar":"ما مدى جاهزية الموظف لتحمل مسؤوليات أكبر في المستقبل القريب؟","text_en":"ما مدى جاهزية الموظف لتحمل مسؤوليات أكبر في المستقبل القريب؟"}]}]}],"questions":[{"id":"me-1","type":"rating_1_5","text_ar":"ما مدى تحقيق الموظف للأهداف والمؤشرات المحددة للفترة؟","text_en":"ما مدى تحقيق الموظف للأهداف والمؤشرات المحددة للفترة؟"},{"id":"me-2","type":"rating_1_5","text_ar":"ما مدى جودة مخرجات العمل والالتزام بالمواعيد النهائية؟","text_en":"ما مدى جودة مخرجات العمل والالتزام بالمواعيد النهائية؟"},{"id":"me-3","type":"rating_1_5","text_ar":"ما مدى قدرة الموظف على العمل تحت الضغط مع الحفاظ على الجودة؟","text_en":"ما مدى قدرة الموظف على العمل تحت الضغط مع الحفاظ على الجودة؟"},{"id":"me-4","type":"rating_1_5","text_ar":"ما مدى فعالية الموظف في التعاون والتواصل مع الزملاء والإدارات؟","text_en":"ما مدى فعالية الموظف في التعاون والتواصل مع الزملاء والإدارات؟"},{"id":"me-5","type":"rating_1_5","text_ar":"ما مدى استجابة الموظف للتغذية الراجعة وخطط التطوير؟","text_en":"ما مدى استجابة الموظف للتغذية الراجعة وخطط التطوير؟"},{"id":"me-6","type":"rating_1_5","text_ar":"ما مدى جاهزية الموظف لتحمل مسؤوليات أكبر في المستقبل القريب؟","text_en":"ما مدى جاهزية الموظف لتحمل مسؤوليات أكبر في المستقبل القريب؟"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'نموذج تقييم المدير للموظف'
);

