insert into public.evaluation_templates (category, title, questions_jsonb)
select 'IT', 'تقييم البنية التحتية التقنية والدعم الفني', '{"version":3,"title_en":"IT Infrastructure and Support Evaluation","title_ar":"تقييم البنية التحتية التقنية والدعم الفني","categories":[{"title_ar":"البنية التقنية","criteria":[{"title_ar":"ما مدى استقرار الأنظمة وتوفر الخدمة خلال ساعات العمل؟","questions":[{"id":"it-1","type":"rating_1_5","text_ar":"ما مدى استقرار الأنظمة وتوفر الخدمة خلال ساعات العمل؟","text_en":"ما مدى استقرار الأنظمة وتوفر الخدمة خلال ساعات العمل؟"}]},{"title_ar":"ما مدى سرعة استجابة الدعم الفني للتذاكر المفتوحة؟","questions":[{"id":"it-2","type":"rating_1_5","text_ar":"ما مدى سرعة استجابة الدعم الفني للتذاكر المفتوحة؟","text_en":"ما مدى سرعة استجابة الدعم الفني للتذاكر المفتوحة؟"}]},{"title_ar":"ما مدى جودة الحلول الجذرية للمشاكل المتكررة؟","questions":[{"id":"it-3","type":"rating_1_5","text_ar":"ما مدى جودة الحلول الجذرية للمشاكل المتكررة؟","text_en":"ما مدى جودة الحلول الجذرية للمشاكل المتكررة؟"}]}]},{"title_ar":"الأمن والتمكين","criteria":[{"title_ar":"ما مدى وعي الموظفين بممارسات الأمن السيبراني الأساسية؟","questions":[{"id":"it-4","type":"rating_1_5","text_ar":"ما مدى وعي الموظفين بممارسات الأمن السيبراني الأساسية؟","text_en":"ما مدى وعي الموظفين بممارسات الأمن السيبراني الأساسية؟"}]},{"title_ar":"ما مدى ملاءمة صلاحيات الوصول للبيانات دون تعقيد زائد؟","questions":[{"id":"it-5","type":"rating_1_5","text_ar":"ما مدى ملاءمة صلاحيات الوصول للبيانات دون تعقيد زائد؟","text_en":"ما مدى ملاءمة صلاحيات الوصول للبيانات دون تعقيد زائد؟"}]},{"title_ar":"ما مدى جاهزية البنية لدعم التحول الرقمي في قسمك؟","questions":[{"id":"it-6","type":"rating_1_5","text_ar":"ما مدى جاهزية البنية لدعم التحول الرقمي في قسمك؟","text_en":"ما مدى جاهزية البنية لدعم التحول الرقمي في قسمك؟"}]}]}],"questions":[{"id":"it-1","type":"rating_1_5","text_ar":"ما مدى استقرار الأنظمة وتوفر الخدمة خلال ساعات العمل؟","text_en":"ما مدى استقرار الأنظمة وتوفر الخدمة خلال ساعات العمل؟"},{"id":"it-2","type":"rating_1_5","text_ar":"ما مدى سرعة استجابة الدعم الفني للتذاكر المفتوحة؟","text_en":"ما مدى سرعة استجابة الدعم الفني للتذاكر المفتوحة؟"},{"id":"it-3","type":"rating_1_5","text_ar":"ما مدى جودة الحلول الجذرية للمشاكل المتكررة؟","text_en":"ما مدى جودة الحلول الجذرية للمشاكل المتكررة؟"},{"id":"it-4","type":"rating_1_5","text_ar":"ما مدى وعي الموظفين بممارسات الأمن السيبراني الأساسية؟","text_en":"ما مدى وعي الموظفين بممارسات الأمن السيبراني الأساسية؟"},{"id":"it-5","type":"rating_1_5","text_ar":"ما مدى ملاءمة صلاحيات الوصول للبيانات دون تعقيد زائد؟","text_en":"ما مدى ملاءمة صلاحيات الوصول للبيانات دون تعقيد زائد؟"},{"id":"it-6","type":"rating_1_5","text_ar":"ما مدى جاهزية البنية لدعم التحول الرقمي في قسمك؟","text_en":"ما مدى جاهزية البنية لدعم التحول الرقمي في قسمك؟"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم البنية التحتية التقنية والدعم الفني'
);

