-- تقييم فعالية فريق المبيعات
insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Sales', 'تقييم فعالية فريق المبيعات', '{"version":3,"title_en":"Sales Team Effectiveness Evaluation","title_ar":"تقييم فعالية فريق المبيعات","categories":[{"title_ar":"أداء المبيعات","criteria":[{"title_ar":"ما مدى تحقيقك لهدف المبيعات خلال الفترة الماضية؟","questions":[{"id":"sal-1","type":"rating_0_10","text_ar":"ما مدى تحقيقك لهدف المبيعات خلال الفترة الماضية؟","text_en":"ما مدى تحقيقك لهدف المبيعات خلال الفترة الماضية؟"}]},{"title_ar":"ما مدى جودة العملاء المحتملين المقدمين لك من المنشأة؟","questions":[{"id":"sal-2","type":"rating_1_5","text_ar":"ما مدى جودة العملاء المحتملين المقدمين لك من المنشأة؟","text_en":"ما مدى جودة العملاء المحتملين المقدمين لك من المنشأة؟"}]},{"title_ar":"ما مدى فعاليتك في إغلاق الصفقات وإدارة الاعتراضات؟","questions":[{"id":"sal-3","type":"rating_1_5","text_ar":"ما مدى فعاليتك في إغلاق الصفقات وإدارة الاعتراضات؟","text_en":"ما مدى فعاليتك في إغلاق الصفقات وإدارة الاعتراضات؟"}]}]},{"title_ar":"العمليات والأدوات","criteria":[{"title_ar":"ما مدى ملاءمة سياسة التسعير الحالية للسوق؟","questions":[{"id":"sal-4","type":"rating_1_5","text_ar":"ما مدى ملاءمة سياسة التسعير الحالية للسوق؟","text_en":"ما مدى ملاءمة سياسة التسعير الحالية للسوق؟"}]},{"title_ar":"ما مدى كفاية أدوات تتبع العملاء (CRM) لإدارة علاقاتك؟","questions":[{"id":"sal-5","type":"rating_1_5","text_ar":"ما مدى كفاية أدوات تتبع العملاء (CRM) لإدارة علاقاتك؟","text_en":"ما مدى كفاية أدوات تتبع العملاء (CRM) لإدارة علاقاتك؟"}]},{"title_ar":"ما مدى وضوح عملية المبيعات من التسويق حتى التحصيل؟","questions":[{"id":"sal-6","type":"rating_1_5","text_ar":"ما مدى وضوح عملية المبيعات من التسويق حتى التحصيل؟","text_en":"ما مدى وضوح عملية المبيعات من التسويق حتى التحصيل؟"}]}]}],"questions":[{"id":"sal-1","type":"rating_0_10","text_ar":"ما مدى تحقيقك لهدف المبيعات خلال الفترة الماضية؟","text_en":"ما مدى تحقيقك لهدف المبيعات خلال الفترة الماضية؟"},{"id":"sal-2","type":"rating_1_5","text_ar":"ما مدى جودة العملاء المحتملين المقدمين لك من المنشأة؟","text_en":"ما مدى جودة العملاء المحتملين المقدمين لك من المنشأة؟"},{"id":"sal-3","type":"rating_1_5","text_ar":"ما مدى فعاليتك في إغلاق الصفقات وإدارة الاعتراضات؟","text_en":"ما مدى فعاليتك في إغلاق الصفقات وإدارة الاعتراضات؟"},{"id":"sal-4","type":"rating_1_5","text_ar":"ما مدى ملاءمة سياسة التسعير الحالية للسوق؟","text_en":"ما مدى ملاءمة سياسة التسعير الحالية للسوق؟"},{"id":"sal-5","type":"rating_1_5","text_ar":"ما مدى كفاية أدوات تتبع العملاء (CRM) لإدارة علاقاتك؟","text_en":"ما مدى كفاية أدوات تتبع العملاء (CRM) لإدارة علاقاتك؟"},{"id":"sal-6","type":"rating_1_5","text_ar":"ما مدى وضوح عملية المبيعات من التسويق حتى التحصيل؟","text_en":"ما مدى وضوح عملية المبيعات من التسويق حتى التحصيل؟"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم فعالية فريق المبيعات'
);

