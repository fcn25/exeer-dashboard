    questions_jsonb = '{"version":3,"title_en":"Professional Fitness Assessment","title_ar":"تقييم اللياقة المهنية","categories":[{"title_ar":"الامتثال والمؤهلات","criteria":[{"title_ar":"هل تحمل جميع التراخيص والشهادات المهنية المطلوبة لدورك الحالي؟","questions":[{"id":"fit-1","type":"boolean","text_ar":"هل تحمل جميع التراخيص والشهادات المهنية المطلوبة لدورك الحالي؟","text_en":"هل تحمل جميع التراخيص والشهادات المهنية المطلوبة لدورك الحالي؟"}]},{"title_ar":"ما مدى التزامك بتحديث مؤهلاتك المهنية وفق المتطلبات النظامية؟","questions":[{"id":"fit-2","type":"rating_1_5","text_ar":"ما مدى التزامك بتحديث مؤهلاتك المهنية وفق المتطلبات النظامية؟","text_en":"ما مدى التزامك بتحديث مؤهلاتك المهنية وفق المتطلبات النظامية؟"}]},{"title_ar":"ما مدى اكتمال ملفك المهني والوثائق الرسمية في سجلات المنشأة؟","questions":[{"id":"fit-3","type":"rating_1_5","text_ar":"ما مدى اكتمال ملفك المهني والوثائق الرسمية في سجلات المنشأة؟","text_en":"ما مدى اكتمال ملفك المهني والوثائق الرسمية في سجلات المنشأة؟"}]}]},{"title_ar":"الجاهزية والسلامة","criteria":[{"title_ar":"ما مدى قدرتك البدنية والذهنية على أداء مهام عملك الحالية؟","questions":[{"id":"fit-4","type":"rating_1_5","text_ar":"ما مدى قدرتك البدنية والذهنية على أداء مهام عملك الحالية؟","text_en":"ما مدى قدرتك البدنية والذهنية على أداء مهام عملك الحالية؟"}]},{"title_ar":"ما مدى التزامك بمعايير السلامة المهنية وإجراءات الجودة؟","questions":[{"id":"fit-5","type":"rating_1_5","text_ar":"ما مدى التزامك بمعايير السلامة المهنية وإجراءات الجودة؟","text_en":"ما مدى التزامك بمعايير السلامة المهنية وإجراءات الجودة؟"}]},{"title_ar":"ما مدى استعدادك للمهام ذات المسؤولية الأعلى خلال الاثني عشر شهراً القادمة؟","questions":[{"id":"fit-6","type":"rating_1_5","text_ar":"ما مدى استعدادك للمهام ذات المسؤولية الأعلى خلال الاثني عشر شهراً القادمة؟","text_en":"ما مدى استعدادك للمهام ذات المسؤولية الأعلى خلال الاثني عشر شهراً القادمة؟"}]}]}],"questions":[{"id":"fit-1","type":"boolean","text_ar":"هل تحمل جميع التراخيص والشهادات المهنية المطلوبة لدورك الحالي؟","text_en":"هل تحمل جميع التراخيص والشهادات المهنية المطلوبة لدورك الحالي؟"},{"id":"fit-2","type":"rating_1_5","text_ar":"ما مدى التزامك بتحديث مؤهلاتك المهنية وفق المتطلبات النظامية؟","text_en":"ما مدى التزامك بتحديث مؤهلاتك المهنية وفق المتطلبات النظامية؟"},{"id":"fit-3","type":"rating_1_5","text_ar":"ما مدى اكتمال ملفك المهني والوثائق الرسمية في سجلات المنشأة؟","text_en":"ما مدى اكتمال ملفك المهني والوثائق الرسمية في سجلات المنشأة؟"},{"id":"fit-4","type":"rating_1_5","text_ar":"ما مدى قدرتك البدنية والذهنية على أداء مهام عملك الحالية؟","text_en":"ما مدى قدرتك البدنية والذهنية على أداء مهام عملك الحالية؟"},{"id":"fit-5","type":"rating_1_5","text_ar":"ما مدى التزامك بمعايير السلامة المهنية وإجراءات الجودة؟","text_en":"ما مدى التزامك بمعايير السلامة المهنية وإجراءات الجودة؟"},{"id":"fit-6","type":"rating_1_5","text_ar":"ما مدى استعدادك للمهام ذات المسؤولية الأعلى خلال الاثني عشر شهراً القادمة؟","text_en":"ما مدى استعدادك للمهام ذات المسؤولية الأعلى خلال الاثني عشر شهراً القادمة؟"}]}'::jsonb
