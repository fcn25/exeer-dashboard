-- تقييم النضج المؤسسي
insert into public.evaluation_templates (category, title, questions_jsonb)
select 'Strategy', 'تقييم النضج المؤسسي', '{"version":3,"title_en":"Institutional Maturity Assessment","title_ar":"تقييم النضج المؤسسي","categories":[{"title_ar":"الهيكلة والحوكمة","criteria":[{"title_ar":"ما مدى وضوح الهيكل التنظيمي وصلاحيات اتخاذ القرار في المنشأة؟","questions":[{"id":"mat-1","type":"rating_1_5","text_ar":"ما مدى وضوح الهيكل التنظيمي وصلاحيات اتخاذ القرار في المنشأة؟","text_en":"ما مدى وضوح الهيكل التنظيمي وصلاحيات اتخاذ القرار في المنشأة؟"}]},{"title_ar":"ما مدى فعالية آليات الرقابة الداخلية والامتثال؟","questions":[{"id":"mat-2","type":"rating_1_5","text_ar":"ما مدى فعالية آليات الرقابة الداخلية والامتثال؟","text_en":"ما مدى فعالية آليات الرقابة الداخلية والامتثال؟"}]},{"title_ar":"ما مدى اكتمال وتحديث السياسات والإجراءات المؤسسية؟","questions":[{"id":"mat-3","type":"rating_1_5","text_ar":"ما مدى اكتمال وتحديث السياسات والإجراءات المؤسسية؟","text_en":"ما مدى اكتمال وتحديث السياسات والإجراءات المؤسسية؟"}]}]},{"title_ar":"النضج الاستراتيجي","criteria":[{"title_ar":"ما مدى اتساق الأهداف الاستراتيجية مع العمليات اليومية؟","questions":[{"id":"mat-4","type":"rating_1_5","text_ar":"ما مدى اتساق الأهداف الاستراتيجية مع العمليات اليومية؟","text_en":"ما مدى اتساق الأهداف الاستراتيجية مع العمليات اليومية؟"}]},{"title_ar":"ما مدى قدرة المنشأة على قياس ومراجعة الأداء المؤسسي دورياً؟","questions":[{"id":"mat-5","type":"rating_1_5","text_ar":"ما مدى قدرة المنشأة على قياس ومراجعة الأداء المؤسسي دورياً؟","text_en":"ما مدى قدرة المنشأة على قياس ومراجعة الأداء المؤسسي دورياً؟"}]},{"title_ar":"ما مدى جاهزية المنشأة للتوسع أو التحول وفق خطة واضحة؟","questions":[{"id":"mat-6","type":"rating_1_5","text_ar":"ما مدى جاهزية المنشأة للتوسع أو التحول وفق خطة واضحة؟","text_en":"ما مدى جاهزية المنشأة للتوسع أو التحول وفق خطة واضحة؟"}]}]}],"questions":[{"id":"mat-1","type":"rating_1_5","text_ar":"ما مدى وضوح الهيكل التنظيمي وصلاحيات اتخاذ القرار في المنشأة؟","text_en":"ما مدى وضوح الهيكل التنظيمي وصلاحيات اتخاذ القرار في المنشأة؟"},{"id":"mat-2","type":"rating_1_5","text_ar":"ما مدى فعالية آليات الرقابة الداخلية والامتثال؟","text_en":"ما مدى فعالية آليات الرقابة الداخلية والامتثال؟"},{"id":"mat-3","type":"rating_1_5","text_ar":"ما مدى اكتمال وتحديث السياسات والإجراءات المؤسسية؟","text_en":"ما مدى اكتمال وتحديث السياسات والإجراءات المؤسسية؟"},{"id":"mat-4","type":"rating_1_5","text_ar":"ما مدى اتساق الأهداف الاستراتيجية مع العمليات اليومية؟","text_en":"ما مدى اتساق الأهداف الاستراتيجية مع العمليات اليومية؟"},{"id":"mat-5","type":"rating_1_5","text_ar":"ما مدى قدرة المنشأة على قياس ومراجعة الأداء المؤسسي دورياً؟","text_en":"ما مدى قدرة المنشأة على قياس ومراجعة الأداء المؤسسي دورياً؟"},{"id":"mat-6","type":"rating_1_5","text_ar":"ما مدى جاهزية المنشأة للتوسع أو التحول وفق خطة واضحة؟","text_en":"ما مدى جاهزية المنشأة للتوسع أو التحول وفق خطة واضحة؟"}]}'::jsonb
