-- Full v3 seed for 17 evaluation templates
-- Run in Supabase SQL Editor after backup
-- Fixes empty criteria in Template Preview (categories → criteria → questions)

create unique index if not exists evaluation_templates_title_unique
  on public.evaluation_templates (title);


-- تقييم جودة خدمات الموارد البشرية
insert into public.evaluation_templates (category, title, questions_jsonb)
select 'HR', 'تقييم جودة خدمات الموارد البشرية', '{"version":3,"title_en":"HR Service Quality Evaluation","title_ar":"تقييم جودة خدمات الموارد البشرية","categories":[{"title_ar":"جودة الخدمة والاستجابة","criteria":[{"title_ar":"ما مدى سرعة استجابة قسم الموارد البشرية على استفساراتك وطلباتك خلال الفترة الأخي…","questions":[{"id":"hr-1","type":"rating_1_5","text_ar":"ما مدى سرعة استجابة قسم الموارد البشرية على استفساراتك وطلباتك خلال الفترة الأخيرة؟","text_en":"ما مدى سرعة استجابة قسم الموارد البشرية على استفساراتك وطلباتك خلال الفترة الأخيرة؟"}]},{"title_ar":"ما مدى وضوح الإجراءات والخطوات المطلوبة عند تقديم طلب للموارد البشرية؟","questions":[{"id":"hr-2","type":"rating_1_5","text_ar":"ما مدى وضوح الإجراءات والخطوات المطلوبة عند تقديم طلب للموارد البشرية؟","text_en":"ما مدى وضوح الإجراءات والخطوات المطلوبة عند تقديم طلب للموارد البشرية؟"}]},{"title_ar":"ما مدى رضاك عن جودة التواصل والمتابعة حتى إغلاق الطلب؟","questions":[{"id":"hr-3","type":"rating_1_5","text_ar":"ما مدى رضاك عن جودة التواصل والمتابعة حتى إغلاق الطلب؟","text_en":"ما مدى رضاك عن جودة التواصل والمتابعة حتى إغلاق الطلب؟"}]}]},{"title_ar":"التطوير والعدالة","criteria":[{"title_ar":"ما مدى ملاءمة البرامج التدريبية لمسارك المهني واحتياجاتك الحالية؟","questions":[{"id":"hr-4","type":"rating_1_5","text_ar":"ما مدى ملاءمة البرامج التدريبية لمسارك المهني واحتياجاتك الحالية؟","text_en":"ما مدى ملاءمة البرامج التدريبية لمسارك المهني واحتياجاتك الحالية؟"}]},{"title_ar":"ما مدى عدالة نظام المكافآت والترقيات من وجهة نظرك؟","questions":[{"id":"hr-5","type":"rating_1_5","text_ar":"ما مدى عدالة نظام المكافآت والترقيات من وجهة نظرك؟","text_en":"ما مدى عدالة نظام المكافآت والترقيات من وجهة نظرك؟"}]},{"title_ar":"ما مدى فعالية قسم الموارد البشرية في دعم حل النزاعات أو الملاحظات الوظيفية؟","questions":[{"id":"hr-6","type":"rating_1_5","text_ar":"ما مدى فعالية قسم الموارد البشرية في دعم حل النزاعات أو الملاحظات الوظيفية؟","text_en":"ما مدى فعالية قسم الموارد البشرية في دعم حل النزاعات أو الملاحظات الوظيفية؟"}]}]}],"questions":[{"id":"hr-1","type":"rating_1_5","text_ar":"ما مدى سرعة استجابة قسم الموارد البشرية على استفساراتك وطلباتك خلال الفترة الأخيرة؟","text_en":"ما مدى سرعة استجابة قسم الموارد البشرية على استفساراتك وطلباتك خلال الفترة الأخيرة؟"},{"id":"hr-2","type":"rating_1_5","text_ar":"ما مدى وضوح الإجراءات والخطوات المطلوبة عند تقديم طلب للموارد البشرية؟","text_en":"ما مدى وضوح الإجراءات والخطوات المطلوبة عند تقديم طلب للموارد البشرية؟"},{"id":"hr-3","type":"rating_1_5","text_ar":"ما مدى رضاك عن جودة التواصل والمتابعة حتى إغلاق الطلب؟","text_en":"ما مدى رضاك عن جودة التواصل والمتابعة حتى إغلاق الطلب؟"},{"id":"hr-4","type":"rating_1_5","text_ar":"ما مدى ملاءمة البرامج التدريبية لمسارك المهني واحتياجاتك الحالية؟","text_en":"ما مدى ملاءمة البرامج التدريبية لمسارك المهني واحتياجاتك الحالية؟"},{"id":"hr-5","type":"rating_1_5","text_ar":"ما مدى عدالة نظام المكافآت والترقيات من وجهة نظرك؟","text_en":"ما مدى عدالة نظام المكافآت والترقيات من وجهة نظرك؟"},{"id":"hr-6","type":"rating_1_5","text_ar":"ما مدى فعالية قسم الموارد البشرية في دعم حل النزاعات أو الملاحظات الوظيفية؟","text_en":"ما مدى فعالية قسم الموارد البشرية في دعم حل النزاعات أو الملاحظات الوظيفية؟"}]}'::jsonb
where not exists (
  select 1 from public.evaluation_templates t where t.title = 'تقييم جودة خدمات الموارد البشرية'
);

update public.evaluation_templates
set category = 'HR',
    questions_jsonb = '{"version":3,"title_en":"HR Service Quality Evaluation","title_ar":"تقييم جودة خدمات الموارد البشرية","categories":[{"title_ar":"جودة الخدمة والاستجابة","criteria":[{"title_ar":"ما مدى سرعة استجابة قسم الموارد البشرية على استفساراتك وطلباتك خلال الفترة الأخي…","questions":[{"id":"hr-1","type":"rating_1_5","text_ar":"ما مدى سرعة استجابة قسم الموارد البشرية على استفساراتك وطلباتك خلال الفترة الأخيرة؟","text_en":"ما مدى سرعة استجابة قسم الموارد البشرية على استفساراتك وطلباتك خلال الفترة الأخيرة؟"}]},{"title_ar":"ما مدى وضوح الإجراءات والخطوات المطلوبة عند تقديم طلب للموارد البشرية؟","questions":[{"id":"hr-2","type":"rating_1_5","text_ar":"ما مدى وضوح الإجراءات والخطوات المطلوبة عند تقديم طلب للموارد البشرية؟","text_en":"ما مدى وضوح الإجراءات والخطوات المطلوبة عند تقديم طلب للموارد البشرية؟"}]},{"title_ar":"ما مدى رضاك عن جودة التواصل والمتابعة حتى إغلاق الطلب؟","questions":[{"id":"hr-3","type":"rating_1_5","text_ar":"ما مدى رضاك عن جودة التواصل والمتابعة حتى إغلاق الطلب؟","text_en":"ما مدى رضاك عن جودة التواصل والمتابعة حتى إغلاق الطلب؟"}]}]},{"title_ar":"التطوير والعدالة","criteria":[{"title_ar":"ما مدى ملاءمة البرامج التدريبية لمسارك المهني واحتياجاتك الحالية؟","questions":[{"id":"hr-4","type":"rating_1_5","text_ar":"ما مدى ملاءمة البرامج التدريبية لمسارك المهني واحتياجاتك الحالية؟","text_en":"ما مدى ملاءمة البرامج التدريبية لمسارك المهني واحتياجاتك الحالية؟"}]},{"title_ar":"ما مدى عدالة نظام المكافآت والترقيات من وجهة نظرك؟","questions":[{"id":"hr-5","type":"rating_1_5","text_ar":"ما مدى عدالة نظام المكافآت والترقيات من وجهة نظرك؟","text_en":"ما مدى عدالة نظام المكافآت والترقيات من وجهة نظرك؟"}]},{"title_ar":"ما مدى فعالية قسم الموارد البشرية في دعم حل النزاعات أو الملاحظات الوظيفية؟","questions":[{"id":"hr-6","type":"rating_1_5","text_ar":"ما مدى فعالية قسم الموارد البشرية في دعم حل النزاعات أو الملاحظات الوظيفية؟","text_en":"ما مدى فعالية قسم الموارد البشرية في دعم حل النزاعات أو الملاحظات الوظيفية؟"}]}]}],"questions":[{"id":"hr-1","type":"rating_1_5","text_ar":"ما مدى سرعة استجابة قسم الموارد البشرية على استفساراتك وطلباتك خلال الفترة الأخيرة؟","text_en":"ما مدى سرعة استجابة قسم الموارد البشرية على استفساراتك وطلباتك خلال الفترة الأخيرة؟"},{"id":"hr-2","type":"rating_1_5","text_ar":"ما مدى وضوح الإجراءات والخطوات المطلوبة عند تقديم طلب للموارد البشرية؟","text_en":"ما مدى وضوح الإجراءات والخطوات المطلوبة عند تقديم طلب للموارد البشرية؟"},{"id":"hr-3","type":"rating_1_5","text_ar":"ما مدى رضاك عن جودة التواصل والمتابعة حتى إغلاق الطلب؟","text_en":"ما مدى رضاك عن جودة التواصل والمتابعة حتى إغلاق الطلب؟"},{"id":"hr-4","type":"rating_1_5","text_ar":"ما مدى ملاءمة البرامج التدريبية لمسارك المهني واحتياجاتك الحالية؟","text_en":"ما مدى ملاءمة البرامج التدريبية لمسارك المهني واحتياجاتك الحالية؟"},{"id":"hr-5","type":"rating_1_5","text_ar":"ما مدى عدالة نظام المكافآت والترقيات من وجهة نظرك؟","text_en":"ما مدى عدالة نظام المكافآت والترقيات من وجهة نظرك؟"},{"id":"hr-6","type":"rating_1_5","text_ar":"ما مدى فعالية قسم الموارد البشرية في دعم حل النزاعات أو الملاحظات الوظيفية؟","text_en":"ما مدى فعالية قسم الموارد البشرية في دعم حل النزاعات أو الملاحظات الوظيفية؟"}]}'::jsonb
