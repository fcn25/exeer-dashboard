-- Replace placeholder templates with all 17 real evaluation templates (flat questions_jsonb).
-- employee_evaluations.template_id uses ON DELETE RESTRICT — clear those rows before deleting templates.

alter table public.evaluation_templates
  add column if not exists questions_jsonb jsonb not null default '{"questions":[]}'::jsonb;

delete from public.employee_evaluations;
delete from public.evaluation_templates;

create unique index if not exists evaluation_templates_title_unique
  on public.evaluation_templates (title);

insert into public.evaluation_templates (category, title, questions_jsonb) values
('HR', 'تقييم جودة خدمات الموارد البشرية', $$ {"title_en": "HR Service Quality Evaluation", "title_ar": "تقييم جودة خدمات الموارد البشرية", "questions": [{"id": "q1", "type": "rating_1_5", "text_en": "How easy and fast is your communication with the HR department when you have an inquiry or issue?", "text_ar": "ما مدى سهولة وسرعة تواصلك مع قسم الموارد البشرية عند وجود استفسار أو مشكلة؟"}, {"id": "q2", "type": "rating_1_5", "text_en": "How would you rate the clarity of the procedures for 'promotions' and 'annual raises' within the organization?", "text_ar": "كيف تقيم وضوح إجراءات 'الترقيات' و'الزيادات السنوية' داخل المنشأة؟"}, {"id": "q3", "type": "text", "text_en": "Please mention one initiative taken by the HR department that improved team spirit or your productivity.", "text_ar": "يرجى ذكر مبادرة واحدة قام بها قسم الموارد البشرية أدت إلى تحسين روح الفريق أو إنتاجيتك."}, {"id": "q4", "type": "text", "text_en": "What is one thing you feel is missing in the current 'incentives and rewards' system that you would like to see added?", "text_ar": "ما هو الشيء الذي تشعر أنه مفقود في نظام 'الحوافز والمكافآت' الحالي وتود إضافته؟"}, {"id": "q5", "type": "choice", "options_en": ["Yes", "No", "Need More"], "options_ar": ["نعم", "لا", "أحتاج المزيد"], "text_en": "Do you feel the training courses provided by the organization align with your actual career path?", "text_ar": "هل تشعر أن الدورات التدريبية المقدمة من المنشأة تتوافق مع مسارك المهني الفعلي؟"}, {"id": "q6", "type": "boolean", "text_en": "Are you regularly informed about your performance evaluation and discussed your strengths and weaknesses?", "text_ar": "هل يتم إطلاعك بانتظام على تقييم أدائك ومناقشة نقاط القوة والضعف لديك؟"}, {"id": "q7", "type": "rating_0_10", "text_en": "If asked to rate the 'fairness of treatment' within the organization from 0 to 10, what number would you choose?", "text_ar": "إذا طُلب منك تقييم 'عدالة التعامل' داخل المنشأة من 0 إلى 10، فما الرقم الذي ستختاره؟"}]} $$::jsonb),
('General', 'استبيان الشركة العام', $$ {"title_en": "Company Survey", "title_ar": "استبيان الشركة العام", "questions": [{"id": "q1", "type": "rating_0_10", "text_en": "How satisfied are you with the work environment?", "text_ar": "ما مدى رضاك عن بيئة العمل؟"}, {"id": "q2", "type": "rating_1_5", "text_en": "Do you have sufficient resources and tools to perform your job effectively?", "text_ar": "هل لديك الموارد والأدوات الكافية لأداء عملك بفعالية؟"}, {"id": "q3", "type": "rating_1_5", "text_en": "How clear is the management vision for the organization?", "text_ar": "ما مدى وضوح رؤية الإدارة للمنشأة؟"}, {"id": "q4", "type": "rating_1_5", "text_en": "How supportive is the HR department in addressing your needs?", "text_ar": "ما مدى دعم قسم الموارد البشرية في تلبية احتياجاتك؟"}]} $$::jsonb),
('Compliance', 'تقييم اللياقة المهنية', $$ {"title_en": "Professional Fitness Assessment", "title_ar": "تقييم اللياقة المهنية", "questions": [{"id": "q1", "type": "boolean", "text_en": "Do you hold the necessary licenses and certifications required for your profession?", "text_ar": "هل تحمل التراخيص والشهادات اللازمة المطلوبة لمهنتك؟"}, {"id": "q2", "type": "boolean", "text_en": "Are you compliant with national safety and professional standards?", "text_ar": "هل أنت ملتزم بمعايير السلامة والمعايير المهنية الوطنية؟"}, {"id": "q3", "type": "boolean", "text_en": "Do you have the physical and mental capability to perform your current job duties?", "text_ar": "هل لديك القدرة البدنية والذهنية لأداء مهام عملك الحالي؟"}, {"id": "q4", "type": "file", "text_en": "Please upload a recent photo or document verifying your professional certification.", "text_ar": "يرجى إرفاق صورة أو مستند حديث يثبت شهادتك المهنية."}, {"id": "q5", "type": "file", "text_en": "Please upload the date of your last professional certification update.", "text_ar": "يرجى إرفاق مستند يوضح تاريخ آخر تحديث لشهادتك المهنية."}]} $$::jsonb),
('Management', 'تقييم التنفيذيين ومدراء الأقسام', $$ {"title_en": "Executive and Department Head Evaluation", "title_ar": "تقييم التنفيذيين ومدراء الأقسام", "questions": [{"id": "q1", "type": "rating_1_5", "text_en": "Ability to make decisions", "text_ar": "القدرة على اتخاذ القرارات"}, {"id": "q2", "type": "rating_1_5", "text_en": "Team management skills", "text_ar": "مهارات إدارة الفريق"}, {"id": "q3", "type": "rating_1_5", "text_en": "Strategic thinking", "text_ar": "التفكير الاستراتيجي"}, {"id": "q4", "type": "rating_1_5", "text_en": "Achievement of department KPIs", "text_ar": "تحقيق مؤشرات الأداء الرئيسية للقسم (KPIs)"}, {"id": "q5", "type": "rating_1_5", "text_en": "Crisis resolution capability", "text_ar": "القدرة على حل الأزمات"}, {"id": "q6", "type": "text", "text_en": "Please provide detailed feedback on the manager's performance", "text_ar": "يرجى تقديم ملاحظات مفصلة حول أداء المدير"}]} $$::jsonb),
('Management', 'نموذج تقييم المدير للموظف', $$ {"title_en": "Manager to Employee Form", "title_ar": "نموذج تقييم المدير للموظف", "questions": [{"id": "q1", "type": "rating_1_5", "text_en": "Rate the employee's goal achievement", "text_ar": "قيّم مدى تحقيق الموظف للأهداف"}, {"id": "q2", "type": "rating_1_5", "text_en": "Rate the employee's teamwork skills", "text_ar": "قيّم مهارات العمل الجماعي للموظف"}, {"id": "q3", "type": "rating_1_5", "text_en": "Rate the employee's communication skills", "text_ar": "قيّم مهارات التواصل لدى الموظف"}, {"id": "q4", "type": "text", "text_en": "Provide written feedback on the employee's strengths and areas for improvement", "text_ar": "قدم ملاحظات مكتوبة حول نقاط القوة لدى الموظف ومجالات التحسين"}, {"id": "q5", "type": "text", "text_en": "List the employee's key achievements", "text_ar": "اذكر أهم إنجازات الموظف"}]} $$::jsonb),
('Strategy', 'تقييم النضج المؤسسي', $$ {"title_en": "Institutional Maturity Assessment", "title_ar": "تقييم النضج المؤسسي", "questions": [{"id": "q1", "type": "rating_1_5", "text_en": "To what extent does your organization have a clear and publicly announced business plan for the next three years?", "text_ar": "إلى أي مدى تمتلك المنشأة خطة عمل واضحة ومعلنة للسنوات الثلاث القادمة؟"}, {"id": "q2", "type": "text", "text_en": "List the top 3 routine processes that consume significant time and could be automated or improved.", "text_ar": "اذكر أهم 3 عمليات روتينية تستهلك وقتاً كبيراً ويمكن أتمتتها أو تحسينها."}, {"id": "q3", "type": "choice", "options_en": ["Yes", "No", "To some extent"], "options_ar": ["نعم", "لا", "إلى حد ما"], "text_en": "Does the distribution of tasks and authorities across departments prevent decision overlap?", "text_ar": "هل يمنع توزيع المهام والصلاحيات بين الأقسام تداخل القرارات؟"}, {"id": "q4", "type": "text", "text_en": "In your view, what is the biggest obstacle that could threaten the organization's sustainability in the market today?", "text_ar": "في رأيك، ما هي أكبر عقبة يمكن أن تهدد استدامة المنشأة في السوق اليوم؟"}]} $$::jsonb),
('Culture', 'استبيان ثقافة الابتكار والارتباط الوظيفي', $$ {"title_en": "Innovation Culture and Employee Engagement Survey", "title_ar": "استبيان ثقافة الابتكار والارتباط الوظيفي", "questions": [{"id": "q1", "type": "rating_1_5", "text_en": "Do you feel comfortable suggesting a new development idea, even if it goes against the norm?", "text_ar": "هل تشعر بالراحة في اقتراح فكرة تطويرية جديدة، حتى لو كانت تخالف المألوف؟"}, {"id": "q2", "type": "text", "text_en": "Describe the last time your exceptional effort was recognized, either monetarily or non-monetarily.", "text_ar": "صف آخر مرة تم فيها تقدير جهدك الاستثنائي، سواء مادياً أو معنوياً."}, {"id": "q3", "type": "choice", "options_en": ["Yes", "No", "Other"], "options_ar": ["نعم", "لا", "غير ذلك"], "text_en": "Does the organization provide the necessary tools and technologies to perform your work without technical barriers?", "text_ar": "هل توفر المنشأة الأدوات والتقنيات اللازمة لأداء عملك دون عوائق تقنية؟"}, {"id": "q4", "type": "text", "text_en": "If offered a job with similar benefits elsewhere, what single aspect of Exeer would make you reject the offer?", "text_ar": "إذا عُرضت عليك وظيفة بمزايا مماثلة في مكان آخر، ما هو الجانب الوحيد في 'إكسير' الذي سيجعلك ترفض العرض؟"}]} $$::jsonb),
('Technology', 'تقييم الجاهزية الرقمية والذكاء الاصطناعي', $$ {"title_en": "Digital Readiness and AI Assessment", "title_ar": "تقييم الجاهزية الرقمية والذكاء الاصطناعي", "questions": [{"id": "q1", "type": "rating_1_5", "text_en": "To what extent are you aware of AI tools that can assist you in your daily tasks?", "text_ar": "ما مدى وعيك بأدوات الذكاء الاصطناعي التي يمكن أن تساعدك في مهامك اليومية؟"}, {"id": "q2", "type": "text", "text_en": "What technical skill do you feel you need intensive training in to become more productive?", "text_ar": "ما هي المهارة التقنية التي تشعر أنك بحاجة إلى تدريب مكثف عليها لتصبح أكثر إنتاجية؟"}, {"id": "q3", "type": "boolean", "text_en": "Do you support replacing some repetitive manual tasks with smart programs, even if it requires changing the nature of your work?", "text_ar": "هل تؤيد استبدال بعض المهام اليدوية المتكررة ببرامج ذكية، حتى لو تطلب ذلك تغيير طبيعة عملك؟"}, {"id": "q4", "type": "text", "text_en": "Suggest one task in your department that you believe Exeer should automate immediately.", "text_ar": "اقترح مهمة واحدة في قسمك تعتقد أنه يجب على نظام 'إكسير' أتمتتها فوراً."}]} $$::jsonb),
('Sales', 'تقييم فعالية فريق المبيعات', $$ {"title_en": "Sales Team Effectiveness Evaluation", "title_ar": "تقييم فعالية فريق المبيعات", "questions": [{"id": "q1", "type": "rating_0_10", "text_en": "How satisfied are you with achieving your sales target during the past period?", "text_ar": "ما مدى رضاك عن تحقيقك لهدف المبيعات الخاص بك خلال الفترة الماضية؟"}, {"id": "q2", "type": "rating_1_5", "text_en": "How would you rate the quality of leads provided to you by the organization?", "text_ar": "كيف تقيم جودة العملاء المحتملين (Leads) المقدمين لك من قبل المنشأة؟"}, {"id": "q3", "type": "text", "text_en": "What is the biggest objection you recently encountered from customers, and how did you handle it to close the deal?", "text_ar": "ما هو أكبر اعتراض واجهته مؤخراً من العملاء، وكيف تعاملت معه لإتمام الصفقة؟"}, {"id": "q4", "type": "text", "text_en": "Please mention one skill you feel you need to develop to increase your sales performance.", "text_ar": "يرجى ذكر مهارة واحدة (مثل: التفاوض، الإغلاق، العرض) تشعر أنك بحاجة لتطويرها لزيادة أدائك البيعي."}, {"id": "q5", "type": "choice", "options_en": ["Yes", "No", "Needs Review"], "options_ar": ["نعم", "لا", "يحتاج مراجعة"], "text_en": "Do you feel the current pricing policy for products/services is competitive in the market?", "text_ar": "هل تشعر أن سياسة التسعير الحالية للمنتجات/الخدمات تنافسية في السوق؟"}, {"id": "q6", "type": "boolean", "text_en": "Do you have sufficient technical tools to track your customers (e.g., CRM)?", "text_ar": "هل تمتلك أدوات تقنية كافية لتتبع عملائك (مثل: نظام CRM أو تطبيقات تواصل)؟"}, {"id": "q7", "type": "text", "text_en": "If you were the sales manager for one day, what single change would you make to the sales process to increase revenue by 20%?", "text_ar": "لو كنت مدير المبيعات ليوم واحد، ما هو التغيير الوحيد الذي ستحدثه في عملية المبيعات لزيادة الإيرادات بنسبة 20%؟"}]} $$::jsonb),
('Finance', 'تقييم الكفاءة المالية والامتثال', $$ {"title_en": "Financial Efficiency and Compliance Evaluation", "title_ar": "تقييم الكفاءة المالية والامتثال", "questions": [{"id": "q1", "type": "rating_1_5", "text_en": "How satisfied are you with the speed of processing financial requests?", "text_ar": "ما مدى رضاك عن سرعة معالجة الطلبات المالية (مثل: الإيداعات، المصروفات، أو المطالبات البنكية)؟"}, {"id": "q2", "type": "rating_1_5", "text_en": "How would you rate the clarity of financial forms and requests required from your department?", "text_ar": "كيف تقيم وضوح النماذج والطلبات المالية المطلوبة من قسمك لتنفيذ العمليات؟"}, {"id": "q3", "type": "choice", "options_en": ["Yes", "No", "Need more details"], "options_ar": ["نعم", "لا", "أحتاج تفاصيل أكثر"], "text_en": "Are you provided with periodic budget reports that show actual expenses versus planned ones?", "text_ar": "هل يتم تزويدك بتقارير ميزانية دورية توضح المصروفات الفعلية مقابل المخطط لها؟"}, {"id": "q4", "type": "text", "text_en": "Please describe one challenge you faced when dealing with 'accounting' or 'internal audit' during the past period.", "text_ar": "يرجى وصف تحدٍ واحد واجهته عند التعامل مع 'المحاسبة' أو 'المراجعة الداخلية' خلال الفترة الماضية."}, {"id": "q5", "type": "choice", "options_en": ["Yes", "No", "Needs review"], "options_ar": ["نعم", "لا", "يحتاج مراجعة"], "text_en": "Do you feel that current financial policies help protect organizational resources from waste?", "text_ar": "هل تشعر أن السياسات المالية الحالية تساعد في حماية موارد المنشأة من الهدر؟"}, {"id": "q6", "type": "rating_1_5", "text_en": "How would you rate the accuracy of financial data shared within your department?", "text_ar": "كيف تقيم دقة البيانات المالية التي تتم مشاركتها داخل قسمك؟"}, {"id": "q7", "type": "text", "text_en": "If you could automate one financial process in the organization, which one would it be?", "text_ar": "إذا كان بإمكانك أتمتة عملية مالية واحدة في المنشأة، فما هي؟"}]} $$::jsonb),
('Customer Service', 'تقييم تجربة العميل والتواصل', $$ {"title_en": "Customer Experience and Communication Evaluation", "title_ar": "تقييم تجربة العميل والتواصل", "questions": [{"id": "q1", "type": "rating_1_5", "text_en": "How quickly does the team respond to customer inquiries and complaints across different channels?", "text_ar": "ما مدى سرعة استجابة الفريق لاستفسارات وشكاوى العملاء عبر القنوات المختلفة؟"}, {"id": "q2", "type": "rating_1_5", "text_en": "How would you rate the frontline staff's ability to remain calm and professional when dealing with angry customers?", "text_ar": "كيف تقيم قدرة موظفي الخطوط الأمامية على الحفاظ على الهدوء والاحترافية عند التعامل مع العملاء الغاضبين؟"}, {"id": "q3", "type": "text", "text_en": "Describe one instance where an employee delivered exceptional service to a customer.", "text_ar": "صف موقفاً قدم فيه أحد الموظفين خدمة استثنائية لعميل."}, {"id": "q4", "type": "text", "text_en": "What is the most frequent complaint from the public recently, and what is your root solution suggestion?", "text_ar": "ما هي الشكوى الأكثر تكراراً من الجمهور مؤخراً، وما هو اقتراحك للحل الجذري؟"}, {"id": "q5", "type": "choice", "options_en": ["Yes", "No", "Partially", "Other"], "options_ar": ["نعم", "لا", "جزئياً", "غير ذلك"], "text_en": "Do customer service staff have sufficient authority to resolve customer issues without always referring to management?", "text_ar": "هل يمتلك موظفو خدمة العملاء الصلاحيات الكافية لحل مشاكل العملاء دون الرجوع الدائم للإدارة؟"}, {"id": "q6", "type": "choice", "options_en": ["Yes", "No", "Other"], "options_ar": ["نعم", "لا", "غير ذلك"], "text_en": "Do current databases and communication systems help you access customer information quickly?", "text_ar": "هل تساعد قواعد البيانات وأنظمة الاتصال الحالية في الوصول إلى معلومات العميل بسرعة؟"}, {"id": "q7", "type": "text", "text_en": "If we want to turn every dissatisfied customer into a loyal advocate, what tool or skill should we provide to the team immediately?", "text_ar": "إذا أردنا تحويل كل عميل غير راضٍ إلى مدافع وموالٍ لنا، فما هي الأداة أو المهارة التي يجب أن نوفرها للفريق فوراً؟"}]} $$::jsonb),
('Supply Chain', 'تقييم كفاءة سلسلة الإمداد والمخزون', $$ {"title_en": "Supply Chain and Inventory Efficiency Evaluation", "title_ar": "تقييم كفاءة سلسلة الإمداد والمخزون", "questions": [{"id": "q1", "type": "rating_1_5", "text_en": "To what extent does the actual inventory count match the data recorded in the technical system?", "text_ar": "إلى أي مدى يتطابق الجرد الفعلي للمخزون مع البيانات المسجلة في النظام التقني؟"}, {"id": "q2", "type": "rating_1_5", "text_en": "How would you rate the speed and efficiency of receiving and dispatching operations within the warehouse?", "text_ar": "كيف تقيم سرعة وكفاءة عمليات الاستلام والتسليم داخل المستودع؟"}, {"id": "q3", "type": "choice", "options_en": ["Yes", "No", "Other"], "options_ar": ["نعم", "لا", "غير ذلك"], "text_en": "Are proper safety and storage requirements (ventilation, lighting, shelf arrangement) available in the warehouse?", "text_ar": "هل تتوفر متطلبات السلامة والتخزين السليمة (التهوية، الإضاءة، ترتيب الأرفف) في المستودع؟"}, {"id": "q4", "type": "text", "text_en": "Provide one suggestion for improvement.", "text_ar": "قدم اقتراحاً واحداً للتحسين."}, {"id": "q5", "type": "text", "text_en": "Describe a recent incident or near-miss that occurred in the warehouse and how it can be prevented in the future.", "text_ar": "صف حادثاً أو وشيك الوقوع (Near-miss) حدث مؤخراً في المستودع وكيف يمكن منعه مستقبلاً."}, {"id": "q6", "type": "choice", "options_en": ["Yes", "No", "Partially"], "options_ar": ["نعم", "لا", "جزئياً"], "text_en": "Is there a clear and consistently followed procedure for handling damaged or obsolete items?", "text_ar": "هل يوجد إجراء واضح ومتبع باستمرار للتعامل مع المواد التالفة أو المتقادمة؟"}, {"id": "q7", "type": "choice", "options_en": ["Yes", "No", "Other"], "options_ar": ["نعم", "لا", "غير ذلك"], "text_en": "Do you feel that access and exit permissions for the warehouse are strict enough to prevent loss?", "text_ar": "هل تشعر أن صلاحيات الدخول والخروج للمستودع صارمة بما يكفي لمنع الفقد؟"}, {"id": "q8", "type": "text", "text_en": "If we aim to reduce the time spent on order preparation by 50%, what technological or spatial change would you recommend?", "text_ar": "إذا كنا نهدف إلى تقليل الوقت المستغرق في تجهيز الطلبات بنسبة 50%، فما هو التغيير التقني أو المكاني الذي توصي به؟"}]} $$::jsonb),
('Production', 'تقييم كفاءة الإنتاج والجودة', $$ {"title_en": "Production Efficiency and Quality Evaluation", "title_ar": "تقييم كفاءة الإنتاج والجودة", "questions": [{"id": "q1", "type": "rating_0_100", "text_en": "How continuous is the operation of production lines without unexpected interruptions or technical failures?", "text_ar": "ما مدى استمرارية تشغيل خطوط الإنتاج دون انقطاعات غير متوقعة أو أعطال فنية؟"}, {"id": "q2", "type": "rating_1_5", "text_en": "How would you rate the speed and efficiency of the maintenance team in handling emergency breakdown reports?", "text_ar": "كيف تقيم سرعة وكفاءة فريق الصيانة في التعامل مع بلاغات الأعطال الطارئة؟"}, {"id": "q3", "type": "text", "text_en": "What is the main reason for the presence of defective products or scrap in your department currently?", "text_ar": "ما هو السبب الرئيسي لوجود منتجات معيبة (Defective) أو هدر في قسمك حالياً؟"}, {"id": "q4", "type": "text", "text_en": "Describe the immediate action you take upon detecting a quality issue during the manufacturing process.", "text_ar": "صف الإجراء الفوري الذي تتخذه عند اكتشاف مشكلة في الجودة أثناء عملية التصنيع."}, {"id": "q5", "type": "choice", "options_en": ["Yes", "No", "Sometimes"], "options_ar": ["نعم", "لا", "أحياناً"], "text_en": "Is there full compliance with wearing personal protective equipment (PPE) by all workers in the production area?", "text_ar": "هل هناك التزام تام بارتداء معدات الوقاية الشخصية (PPE) من قبل جميع العمال في منطقة الإنتاج؟"}, {"id": "q6", "type": "rating_1_5", "text_en": "Do you feel that lighting, ventilation, and space layout in the production hall help maintain focus and safety?", "text_ar": "هل تشعر أن الإضاءة، والتهوية، وتخطيط المساحة في صالة الإنتاج تساعد في الحفاظ على التركيز والسلامة؟"}, {"id": "q7", "type": "text", "text_en": "If asked to suggest one change in the manufacturing sequence to increase daily output by 15% without increasing costs, what would it be?", "text_ar": "إذا طُلب منك اقتراح تغيير واحد في تسلسل التصنيع لزيادة الإنتاج اليومي بنسبة 15% دون زيادة التكاليف، فماذا سيكون؟"}]} $$::jsonb),
('IT', 'تقييم البنية التحتية التقنية والدعم الفني', $$ {"title_en": "IT Infrastructure and Support Evaluation", "title_ar": "تقييم البنية التحتية التقنية والدعم الفني", "questions": [{"id": "q1", "type": "rating_1_5", "text_en": "How quickly does the IT team respond when you open a ticket for technical assistance?", "text_ar": "ما مدى سرعة استجابة فريق تقنية المعلومات عند فتح تذكرة لطلب المساعدة الفنية؟"}, {"id": "q2", "type": "rating_1_5", "text_en": "How would you rate the team's ability to resolve recurring issues permanently rather than applying temporary fixes?", "text_ar": "كيف تقيم قدرة الفريق على حل المشاكل المتكررة بشكل جذري بدلاً من الحلول المؤقتة؟"}, {"id": "q3", "type": "text", "text_en": "Which software or system in the organization do you believe urgently needs an update or replacement due to frequent failures?", "text_ar": "ما هو البرنامج أو النظام في المنشأة الذي تعتقد أنه يحتاج بشكل عاجل إلى تحديث أو استبدال بسبب أعطاله المتكررة؟"}, {"id": "q4", "type": "text", "text_en": "Describe the steps you take when encountering a suspicious message or attempted cyberattack (to assess security awareness).", "text_ar": "صف الخطوات التي تتخذها عند مواجهة رسالة مشبوهة أو محاولة اختراق سيبراني (لتقييم الوعي الأمني)."}, {"id": "q5", "type": "choice", "options_en": ["Yes", "No", "I need an upgrade"], "options_ar": ["نعم", "لا", "أحتاج إلى ترقية"], "text_en": "Do you feel that internet speed and availability of appropriate devices allow you to perform your work at peak efficiency?", "text_ar": "هل تشعر أن سرعة الإنترنت وتوفر الأجهزة المناسبة تتيح لك أداء عملك بأقصى كفاءة؟"}, {"id": "q6", "type": "choice", "options_en": ["Yes", "No"], "options_ar": ["نعم", "لا"], "text_en": "Do you have sufficient access rights to the data you need for your job without excessive administrative hurdles?", "text_ar": "هل لديك صلاحيات وصول كافية للبيانات التي تحتاجها لعملك دون تعقيدات إدارية مفرطة؟"}, {"id": "q7", "type": "text", "text_en": "If we could eliminate one paper-based process in your department and fully digitize it, what would it be?", "text_ar": "إذا كان بإمكاننا التخلص من عملية ورقية واحدة في قسمك ورقمنتها بالكامل، فما هي؟"}]} $$::jsonb),
('Procurement', 'تقييم كفاءة المشتريات وسلاسل الإمداد', $$ {"title_en": "Procurement and Supply Chain Efficiency Evaluation", "title_ar": "تقييم كفاءة المشتريات وسلاسل الإمداد", "questions": [{"id": "q1", "type": "rating_0_100", "text_en": "How quickly does procurement management fulfill purchase requests from your department since approval?", "text_ar": "ما مدى سرعة إدارة المشتريات في تلبية طلبات الشراء الخاصة بقسمك بعد الموافقة عليها؟"}, {"id": "q2", "type": "rating_1_5", "text_en": "How would you rate the quality of supplied materials or services compared to the specifications requested in the purchase order?", "text_ar": "كيف تقيم جودة المواد أو الخدمات الموردة مقارنة بالمواصفات المطلوبة في أمر الشراء؟"}, {"id": "q3", "type": "text", "text_en": "Have you experienced repeated operational downtime due to delays from a specific supplier? Please describe the situation and how it was handled.", "text_ar": "هل واجهت تعطلاً تشغيلياً متكرراً بسبب تأخير من مورد معين؟ يرجى وصف الموقف وكيف تم التعامل معه."}, {"id": "q4", "type": "text", "text_en": "Provide one suggestion to simplify the process of approving new suppliers to ensure better pricing and quality.", "text_ar": "قدم اقتراحاً لتبسيط عملية اعتماد موردين جدد لضمان أسعار وجودة أفضل."}, {"id": "q5", "type": "choice", "options_en": ["Yes", "No", "Requires legal review"], "options_ar": ["نعم", "لا", "تتطلب مراجعة قانونية"], "text_en": "Do you feel that contracts with current service providers adequately protect the organization's rights?", "text_ar": "هل تشعر أن العقود مع مقدمي الخدمات الحاليين تحمي حقوق المنشأة بشكل كافٍ؟"}, {"id": "q6", "type": "choice", "options_en": ["Yes", "No"], "options_ar": ["نعم", "لا"], "text_en": "Are you regularly informed about renewal or expiration dates of contracts related to your department?", "text_ar": "هل يتم إبلاغك بانتظام بتواريخ تجديد أو انتهاء العقود المتعلقة بقسمك؟"}, {"id": "q7", "type": "text", "text_en": "If asked to propose a mechanism to reduce annual procurement costs by 10% without compromising quality, what would it be?", "text_ar": "إذا طُلب منك اقتراح آلية لتقليل تكاليف المشتريات السنوية بنسبة 10% دون المساس بالجودة، فماذا ستكون؟"}]} $$::jsonb),
('Marketing', 'تقييم قوة العلامة التجارية وفعالية التسويق', $$ {"title_en": "Brand Strength and Marketing Effectiveness Evaluation", "title_ar": "تقييم قوة العلامة التجارية وفعالية التسويق", "questions": [{"id": "q1", "type": "rating_1_5", "text_en": "To what extent do you feel the visual identity of the organization reflects its true values?", "text_ar": "إلى أي مدى تشعر أن الهوية البصرية للمنشأة تعكس قيمها الحقيقية؟"}, {"id": "q2", "type": "rating_1_5", "text_en": "How easy is it for you to explain the organization's services/products to a stranger based on the available marketing materials?", "text_ar": "ما مدى سهولة شرحك لخدمات/منتجات المنشأة لشخص غريب بناءً على المواد التسويقية المتاحة؟"}, {"id": "q3", "type": "text", "text_en": "Which one marketing channel (social media, advertising, public relations) do you believe is currently the most effective in attracting customers, and why?", "text_ar": "ما هي القناة التسويقية (سوشيال ميديا، إعلانات، علاقات عامة) التي تعتقد أنها الأكثر فعالية حالياً في جذب العملاء، ولماذا؟"}, {"id": "q4", "type": "text", "text_en": "What is the first impression the organization's name leaves in a customer's mind upon hearing it for the first time?", "text_ar": "ما هو الانطباع الأول الذي يتركه اسم المنشأة في ذهن العميل عند سماعه لأول مرة؟"}, {"id": "q5", "type": "choice", "options_en": ["Yes", "No", "We need out-of-the-box ideas"], "options_ar": ["نعم", "لا", "نحتاج أفكار خارج الصندوق"], "text_en": "Do you feel our current marketing campaigns outperform direct competitors in the market?", "text_ar": "هل تشعر أن حملاتنا التسويقية الحالية تتفوق على المنافسين المباشرين في السوق؟"}, {"id": "q6", "type": "choice", "options_en": ["Yes", "No"], "options_ar": ["نعم", "لا"], "text_en": "Are you regularly provided with updated promotional materials to support your work?", "text_ar": "هل يتم تزويدك بانتظام بمواد ترويجية محدثة لدعم عملك؟"}, {"id": "q7", "type": "text", "text_en": "If we had an open marketing budget for one month, what creative initiative would you propose to increase brand awareness?", "text_ar": "إذا كان لدينا ميزانية تسويق مفتوحة لشهر واحد، فما هي المبادرة الإبداعية التي ستقترحها لزيادة الوعي بالعلامة التجارية؟"}]} $$::jsonb),
('General', 'التقييم الذاتي للموظف', $$ {"title_en": "Employee Self Evaluation", "title_ar": "التقييم الذاتي للموظف", "questions": [{"id": "q1", "type": "text", "text_en": "What are my key achievements during this period?", "text_ar": "ما هي أبرز إنجازاتي خلال هذه الفترة؟"}, {"id": "q2", "type": "rating_1_5", "text_en": "How would I rate my commitment to the goals assigned to me?", "text_ar": "كيف أقيم التزامي بالأهداف المحددة لي؟"}, {"id": "q3", "type": "text", "text_en": "What challenges have I faced?", "text_ar": "ما هي التحديات التي واجهتها؟"}, {"id": "q4", "type": "text", "text_en": "What skills do I wish to develop in the future?", "text_ar": "ما هي المهارات التي أرغب في تطويرها مستقبلاً؟"}]} $$::jsonb);
